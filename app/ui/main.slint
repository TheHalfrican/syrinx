// Syrinx — main window. Themed shell + TTS workspace, wired to the engine.
import { Theme } from "theme.slint";
import { ScrollView } from "std-widgets.slint";

export struct VoiceItem { id: string, name: string, desc: string, lang: string, kind: string }
export struct HistItem { id: string, voice: string, meta: string, text: string, starred: bool }

// --- Win95 3D bevel overlay (transparent center; draws a doubled 2px edge) ---
// raised (default) = light top/left, dark bottom/right; sunken flips it (fields, pressed).
component Bevel inherits Rectangle {
    in property <bool> sunken: false;
    property <color> tl1: sunken ? #808080 : #ffffff;   // outer top-left
    property <color> br1: sunken ? #ffffff : #404040;   // outer bottom-right
    property <color> tl2: sunken ? #404040 : #d4d0c8;   // inner top-left
    property <color> br2: sunken ? #d4d0c8 : #808080;   // inner bottom-right
    // outer edge
    Rectangle { x: 0; y: 0; width: parent.width; height: 1px; background: tl1; }
    Rectangle { x: 0; y: 0; width: 1px; height: parent.height; background: tl1; }
    Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: br1; }
    Rectangle { x: parent.width - 1px; y: 0; width: 1px; height: parent.height; background: br1; }
    // inner edge (inset 1px)
    Rectangle { x: 1px; y: 1px; width: parent.width - 2px; height: 1px; background: tl2; }
    Rectangle { x: 1px; y: 1px; width: 1px; height: parent.height - 2px; background: tl2; }
    Rectangle { x: 1px; y: parent.height - 2px; width: parent.width - 2px; height: 1px; background: br2; }
    Rectangle { x: parent.width - 2px; y: 1px; width: 1px; height: parent.height - 2px; background: br2; }
}

// --- sidebar nav icon ---
component NavIcon inherits Rectangle {
    in property <string> glyph;
    in property <bool> active;
    callback clicked;
    width: 42px; height: 42px; border-radius: Theme.rad;
    background: active ? Theme.acc : (ta.has-hover ? Theme.acc-soft : transparent);
    ta := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: glyph; font-size: 18px;
        color: active ? Theme.acc-fg : Theme.dim;
        horizontal-alignment: center; vertical-alignment: center;
    }
}

// --- themed button (variant: generate = accent) ---
component TBtn inherits Rectangle {
    in property <string> label;
    in property <bool> generate;
    callback clicked;
    property <bool> win95: Theme.name == "win95";
    height: 30px;
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1px;
    border-color: generate ? Theme.acc : Theme.btn-brd;
    background: win95 ? (generate ? Theme.gen-bg : Theme.btn-bg)
             : (ta2.pressed ? Theme.acc-soft : (generate ? Theme.gen-bg : Theme.btn-bg));
    horizontal-stretch: 0;
    ta2 := TouchArea { clicked => { root.clicked(); } }
    HorizontalLayout {
        padding-left: 13px; padding-right: 13px;
        Text {
            text: label; font-size: 12px;
            font-weight: generate ? 700 : 500;
            font-family: Theme.font;
            color: generate ? Theme.gen-fg : Theme.btn-fg;
            vertical-alignment: center; horizontal-alignment: center;
        }
    }
    if win95 : Bevel { width: 100%; height: 100%; sunken: ta2.pressed; }
}

component Chip inherits Rectangle {
    in property <string> label;
    background: Theme.chip-bg; border-radius: Theme.rad;
    height: 18px;
    HorizontalLayout {
        padding-left: 7px; padding-right: 7px;
        Text { text: label; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
    }
}

component VoiceCard inherits Rectangle {
    in property <VoiceItem> v;
    in property <string> selected;
    property <bool> active: v.id == selected;
    property <bool> win95: Theme.name == "win95";
    callback clicked;
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1.5px;
    border-color: active ? Theme.acc : (ta.has-hover ? Theme.acc : Theme.brd);
    background: Theme.card-bg;
    clip: true;
    ta := TouchArea { clicked => { root.clicked(); } }
    if win95 : Bevel { width: 100%; height: 100%; sunken: active; }
    VerticalLayout {
        padding: 13px; spacing: 4px;
        HorizontalLayout {
            spacing: 8px;
            Text { text: v.name; font-size: 14px; font-weight: 700; color: Theme.fg; overflow: elide; }
            if active : Rectangle {
                background: Theme.acc; border-radius: 9px;
                HorizontalLayout {
                    padding-left: 7px; padding-right: 7px;
                    Text { text: "ACTIVE"; font-size: 9px; font-weight: 700; color: Theme.acc-fg; vertical-alignment: center; }
                }
            }
            Rectangle {}
        }
        Text { text: v.desc; font-size: 11.5px; color: Theme.dim; wrap: word-wrap; }
        Rectangle {}  // flex spacer — push chips to the bottom
        HorizontalLayout {
            spacing: 6px; alignment: start;
            Chip { label: v.lang; }
            Chip { label: v.kind; }
        }
    }
}

// --- themed dropdown (replaces the std ComboBox so it matches every skin) ---
component ThemedDropdown inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    callback selected(int);
    property <bool> win95: Theme.name == "win95";
    height: 30px;
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1px;
    border-color: Theme.btn-brd;
    background: win95 ? #ffffff : Theme.card-bg;
    if win95 : Bevel { width: 100%; height: 100%; sunken: true; }
    HorizontalLayout {
        padding-left: 10px; padding-right: 6px; spacing: 4px;
        Text {
            text: model[current-index]; font-size: 12px; color: Theme.fg; font-family: Theme.font;
            vertical-alignment: center; overflow: elide; horizontal-stretch: 1;
        }
        Text { text: "▾"; font-size: 10px; color: Theme.dim; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { popup.show(); } }
    popup := PopupWindow {
        x: 0; y: root.height + 2px;
        width: root.width;
        height: min(model.length * 26px + 4px, 210px);
        close-policy: close-on-click-outside;
        Rectangle {
            background: win95 ? #ffffff : Theme.card-bg;
            border-width: win95 ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
            if win95 : Bevel { width: 100%; height: 100%; }
            ScrollView {
                VerticalLayout {
                    padding: 2px;
                    for opt[i] in model : Rectangle {
                        height: 26px;
                        background: (i == current-index || ita.has-hover) ? Theme.acc-soft : transparent;
                        ita := TouchArea {
                            clicked => { root.current-index = i; root.selected(i); popup.close(); }
                        }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 8px;
                            Text {
                                text: opt; font-size: 12px; color: Theme.fg; font-family: Theme.font;
                                vertical-alignment: center; overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}

// --- "Kokoro Defaults" card: bundled presets collapsed behind a dropdown ---
component KokoroCard inherits Rectangle {
    in property <string> selected;
    in property <bool> active;
    in property <[string]> names;
    in property <[string]> ids;
    callback pick(string);
    property <bool> win95: Theme.name == "win95";
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1.5px;
    border-color: active ? Theme.acc : Theme.brd;
    background: Theme.card-bg;
    clip: true;
    if win95 : Bevel { width: 100%; height: 100%; sunken: active; }
    VerticalLayout {
        padding: 13px; spacing: 6px;
        HorizontalLayout {
            spacing: 8px;
            Text { text: "Kokoro Defaults"; font-size: 14px; font-weight: 700; color: Theme.fg; }
            Rectangle {}
            if active : Rectangle {
                background: Theme.acc; border-radius: 9px;
                HorizontalLayout {
                    padding-left: 7px; padding-right: 7px;
                    Text { text: "ACTIVE"; font-size: 9px; font-weight: 700; color: Theme.acc-fg; vertical-alignment: center; }
                }
            }
        }
        Text { text: names.length + " bundled preset voices"; font-size: 11.5px; color: Theme.dim; }
        Rectangle {}  // flex spacer
        ThemedDropdown {
            model: names;
            current-index: 0;
            selected(i) => { root.pick(ids[i]); }
        }
    }
}

// --- a single row-menu entry ---
component MenuItem inherits Rectangle {
    in property <string> label;
    in property <color> tint: Theme.fg;
    in property <bool> enabled: true;
    callback chosen();
    height: 28px; border-radius: Theme.rad;
    background: (enabled && mi.has-hover) ? Theme.acc-soft : transparent;
    mi := TouchArea { enabled: root.enabled; clicked => { root.chosen(); } }
    HorizontalLayout {
        padding-left: 10px; padding-right: 10px;
        Text {
            text: label; font-size: 12px; font-family: Theme.font; vertical-alignment: center;
            color: enabled ? tint : Theme.dim; opacity: enabled ? 1.0 : 0.5;
        }
    }
}

// --- per-row 3-dot menu (history actions) ---
component RowMenu inherits Rectangle {
    callback play();
    callback regen();
    callback export-audio();
    callback export-package();
    callback del();
    property <bool> win95: Theme.name == "win95";
    width: 24px; height: 24px; border-radius: Theme.rad;
    background: ta.has-hover ? Theme.acc-soft : transparent;
    ta := TouchArea { clicked => { pop.show(); } }
    Text { text: "⋮"; font-size: 16px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
    pop := PopupWindow {
        x: root.width - 176px; y: root.height + 2px;
        width: 176px; height: 190px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: win95 ? #ffffff : Theme.card-bg;
            border-width: win95 ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
            if win95 : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                padding: 3px;
                MenuItem { label: "Play"; chosen => { root.play(); pop.close(); } }
                MenuItem { label: "Regenerate"; chosen => { root.regen(); pop.close(); } }
                MenuItem { label: "Export audio"; chosen => { root.export-audio(); pop.close(); } }
                MenuItem { label: "Export package"; chosen => { root.export-package(); pop.close(); } }
                MenuItem { label: "Apply effects"; enabled: false; }
                Rectangle { height: 1px; background: Theme.brd; }
                MenuItem { label: "Delete"; tint: #cc3b3b; chosen => { root.del(); pop.close(); } }
            }
        }
    }
}

// --- labeled text field (create-voice modal) ---
component LabeledInput inherits VerticalLayout {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> multiline: false;
    in-out property <string> value;
    spacing: 4px;
    Text { text: label; font-size: 11px; font-weight: 700; color: Theme.dim; }
    Rectangle {
        height: multiline ? 60px : 30px;
        background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
        border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
        clip: true;
        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
        if value == "" : Text {
            x: 9px; y: 7px; text: placeholder; font-size: 12.5px; color: Theme.dim; opacity: 0.6;
            font-family: Theme.font;
        }
        TextInput {
            x: 9px; y: 6px; width: parent.width - 18px; height: parent.height - 12px;
            text <=> value; font-size: 13px; color: Theme.fg; font-family: Theme.font;
            wrap: multiline ? word-wrap : no-wrap; single-line: !multiline;
        }
    }
}

export component AppWindow inherits Window {
    title: "Syrinx";
    preferred-width: 1180px;
    preferred-height: 760px;
    background: Theme.win-bg;
    default-font-family: Theme.font;

    // --- state exposed to Rust ---
    in property <[VoiceItem]> voices;   // grid items: [Kokoro card, user voices…, spacers]
    in property <[string]> kokoro-names;
    in property <[string]> kokoro-ids;
    in-out property <bool> kokoro-active: true;
    in property <[HistItem]> history;
    in-out property <string> selected-voice;
    in-out property <string> text;
    in property <bool> generating;
    in property <float> level;
    in property <string> backend: "cpu";
    // --- player (full-clip waveform + scrub) ---
    in property <bool> player-active;
    in property <[float]> player-bars;
    in-out property <float> play-pct;
    in property <string> player-title;
    in property <string> player-id;
    in property <string> player-time;
    in property <bool> player-playing;
    in-out property <bool> player-paused;
    in property <bool> synthesizing;
    // --- create-voice modal ---
    in-out property <bool> cv-open: false;
    in-out property <string> cv-mode: "record";   // record | upload | system
    in property <bool> cv-recording;
    in property <bool> cv-transcribing;
    in property <bool> cv-creating;
    in property <string> cv-sample-label;
    in-out property <string> cv-name;
    in-out property <string> cv-desc;
    in-out property <string> cv-personality;
    in-out property <string> cv-transcript;
    in-out property <string> cv-language: "en";

    callback generate();
    callback stop();
    callback select-voice(string);
    callback play-hist(string);
    callback star-hist(string, bool);
    callback delete-hist(string);
    callback regen-hist(string);
    callback export-audio(string);
    callback export-package(string);
    callback pause();
    callback resume();
    callback seek(string, float);
    callback cv-start-record();
    callback cv-stop-record();
    callback cv-pick-file();
    callback cv-transcribe();
    callback cv-create();
    callback cv-cancel();

    property <string> tab: "tts";

    // --- Aero background image (behind everything; only for the vista skin) ---
    if Theme.name == "vista" : Image {
        source: @image-url("assets/backgrounds/Aero.png");
        image-fit: cover;
        x: 0; y: 0;
        width: root.width;
        height: root.height;
    }

    VerticalLayout {
        width: 100%;
        height: 100%;
        // --- title bar ---
        Rectangle {
            height: 38px; background: Theme.tb-bg;
            HorizontalLayout {
                padding-left: 12px; padding-right: 12px; spacing: 10px;
                Rectangle {
                    width: 16px; height: 16px; border-radius: 4px; y: parent.height / 2 - 8px;
                    background: @linear-gradient(135deg, Theme.acc, Theme.wave-dim);
                }
                Text { text: "Syrinx"; font-size: 13px; font-weight: 600; color: Theme.tb-fg; vertical-alignment: center; }
                Text { text: "— local AI voice studio"; font-size: 11.5px; color: Theme.tb-fg; opacity: 0.65; vertical-alignment: center; }
                Rectangle {}
                Text { text: "hyprland · workspace 3"; font-size: 10.5px; font-family: Theme.mono; color: Theme.tb-fg; opacity: 0.55; vertical-alignment: center; }
            }
        }

        HorizontalLayout {
            // --- icon rail ---
            Rectangle {
                width: 62px; background: Theme.side-bg;
                border-width: 1px; border-color: Theme.brd;
                VerticalLayout {
                    padding-top: 12px; padding-bottom: 12px; spacing: 4px; alignment: start;
                    HorizontalLayout { alignment: center; NavIcon { glyph: "▷"; active: tab == "tts"; clicked => { tab = "tts"; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "◍"; active: tab == "voices"; clicked => { tab = "voices"; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "☰"; active: tab == "stt"; clicked => { tab = "stt"; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "⇄"; active: tab == "vc"; clicked => { tab = "vc"; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "▤"; active: tab == "lib"; clicked => { tab = "lib"; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "◈"; active: tab == "models"; clicked => { tab = "models"; } } }
                    Rectangle {}
                    HorizontalLayout { alignment: center; NavIcon { glyph: "⚙"; active: tab == "settings"; clicked => { tab = "settings"; } } }
                }
            }

            // --- main panel ---
            Rectangle {
                background: Theme.pan-bg;
                VerticalLayout {
                    // header + theme switcher
                    HorizontalLayout {
                        padding: 16px; spacing: 14px;
                        VerticalLayout {
                            spacing: 2px;
                            Text { text: tab == "tts" ? "Text to Speech" : "Coming soon"; font-size: 19px; font-weight: 700; color: Theme.name == "win95" ? #ffffff : Theme.fg; }
                            Text {
                                text: tab == "tts" ? "Type it, pick a voice, hear it — all local." : "This screen is stubbed for now.";
                                font-size: 12px; color: Theme.name == "win95" ? #cfe6e6 : Theme.dim;
                            }
                        }
                        Rectangle {}
                        // theme switcher (sets the Theme global directly)
                        Rectangle {
                            border-width: 1px; border-color: Theme.brd; border-radius: Theme.rad; background: Theme.card-bg;
                            HorizontalLayout {
                                padding: 4px; spacing: 4px;
                                for th[i] in [
                                    { k: "vista", l: "Aero" }, { k: "win95", l: "'95" },
                                    { k: "ps5", l: "Astro" }, { k: "rice", l: "Rice" }, { k: "tui", l: "TTY" }
                                ] : Rectangle {
                                    border-radius: Theme.rad;
                                    background: Theme.name == th.k ? Theme.acc : transparent;
                                    tta := TouchArea { clicked => { Theme.name = th.k; } }
                                    HorizontalLayout {
                                        padding-left: 10px; padding-right: 10px;
                                        Text {
                                            text: th.l; font-size: 11.5px; vertical-alignment: center;
                                            color: Theme.name == th.k ? Theme.acc-fg : Theme.dim;
                                        }
                                    }
                                    height: 26px;
                                }
                            }
                        }
                    }

                    // ---- TTS workspace ----
                    if tab == "tts" : HorizontalLayout {
                        padding-left: 22px; padding-right: 22px; spacing: 18px;

                        // voices column
                        VerticalLayout {
                            horizontal-stretch: 5; spacing: 10px;
                            HorizontalLayout {
                                spacing: 10px;
                                Text { text: "VOICES"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" ? #ffffff : Theme.dim; vertical-alignment: center; }
                                Rectangle {}
                                TBtn { label: "Import voice"; clicked => {} }
                                TBtn { label: "✦ Create voice"; generate: true; clicked => { cv-open = true; } }
                            }
                            ScrollView {
                                // 3-column card grid (model padded to a multiple of 3 in Rust,
                                // so exactly 3 equal columns always render)
                                GridLayout {
                                    spacing: 16px;
                                    for v[i] in voices : Rectangle {
                                        row: floor(i / 3);
                                        col: i - floor(i / 3) * 3;
                                        height: 162px;
                                        if v.kind == "model-defaults" : KokoroCard {
                                            width: 100%; height: 100%;
                                            selected: root.selected-voice;
                                            active: root.kokoro-active;
                                            names: root.kokoro-names;
                                            ids: root.kokoro-ids;
                                            pick(id) => {
                                                root.selected-voice = id;
                                                root.kokoro-active = true;
                                                root.select-voice(id);
                                            }
                                        }
                                        if v.kind != "model-defaults" && v.kind != "empty" : VoiceCard {
                                            width: 100%; height: 100%;
                                            v: v;
                                            selected: root.selected-voice;
                                            clicked => {
                                                root.selected-voice = v.id;
                                                root.kokoro-active = false;
                                                root.select-voice(v.id);
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // history column
                        Rectangle {
                            horizontal-stretch: 4;
                            // left divider (the mockup uses a single left border, not a box)
                            Rectangle { x: 0; y: 0; width: 1px; height: 100%; background: Theme.brd; }
                            VerticalLayout {
                                padding-left: 18px; spacing: 10px;
                                Text { text: "HISTORY"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" ? #ffffff : Theme.dim; }
                                ScrollView {
                                    VerticalLayout {
                                        spacing: 8px;
                                        for h[i] in history : Rectangle {
                                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad; background: Theme.card-bg;
                                            clip: true;
                                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                            VerticalLayout {
                                                padding: 11px; spacing: 8px;
                                                HorizontalLayout {
                                                    spacing: 8px;
                                                    // round play button
                                                    Rectangle {
                                                        width: 28px; height: 28px;
                                                        border-radius: Theme.name == "win95" ? 0px : 14px;
                                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                                        border-color: Theme.btn-brd;
                                                        background: (pb.pressed && Theme.name != "win95") ? Theme.acc-soft : Theme.btn-bg;
                                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: pb.pressed; }
                                                        pb := TouchArea { clicked => { root.play-hist(h.id); } }
                                                        Text { text: "▶"; font-size: 10px; color: Theme.btn-fg;
                                                               horizontal-alignment: center; vertical-alignment: center; }
                                                    }
                                                    // voice + meta
                                                    VerticalLayout {
                                                        alignment: center; spacing: 1px; horizontal-stretch: 1;
                                                        Text { text: h.voice; font-size: 12.5px; font-weight: 700; color: Theme.fg; overflow: elide; }
                                                        Text { text: h.meta; font-size: 10px; font-family: Theme.mono; color: Theme.dim; overflow: elide; }
                                                    }
                                                    // mini waveform (decorative until level data is wired)
                                                    Rectangle {
                                                        height: 22px;
                                                        HorizontalLayout {
                                                            spacing: 2px; alignment: end;
                                                            for bh in [7, 12, 8, 16, 10, 18, 9, 14, 11, 15] : VerticalLayout {
                                                                alignment: end;
                                                                Rectangle { width: 3px; height: bh * 1px; border-radius: 1px; background: Theme.wave-dim; }
                                                            }
                                                        }
                                                    }
                                                    // star toggle (always visible, Voicebox-style)
                                                    Rectangle {
                                                        width: 22px; height: 22px; border-radius: Theme.rad;
                                                        background: sta.has-hover ? Theme.acc-soft : transparent;
                                                        sta := TouchArea { clicked => { root.star-hist(h.id, !h.starred); } }
                                                        Text { text: h.starred ? "★" : "☆"; font-size: 14px;
                                                               color: h.starred ? Theme.acc : Theme.dim;
                                                               horizontal-alignment: center; vertical-alignment: center; }
                                                    }
                                                    // 3-dot menu
                                                    RowMenu {
                                                        play => { root.play-hist(h.id); }
                                                        regen => { root.regen-hist(h.id); }
                                                        export-audio => { root.export-audio(h.id); }
                                                        export-package => { root.export-package(h.id); }
                                                        del => { root.delete-hist(h.id); }
                                                    }
                                                }
                                                // message text, clamped to ~2 lines
                                                Rectangle {
                                                    height: 32px; clip: true;
                                                    Text {
                                                        width: 100%; text: h.text; font-size: 11.5px; color: Theme.dim;
                                                        wrap: word-wrap; vertical-alignment: top;
                                                    }
                                                }
                                            }
                                        }
                                        if history.length == 0 : Text {
                                            text: "— nothing generated yet —"; font-size: 10.5px; font-family: Theme.mono;
                                            color: Theme.dim; horizontal-alignment: center;
                                        }
                                        if history.length > 0 : Text {
                                            text: "— end of history —"; font-size: 10.5px; font-family: Theme.mono;
                                            color: Theme.dim; horizontal-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ---- stub for other tabs ----
                    if tab != "tts" : Rectangle {
                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                alignment: center; spacing: 10px;
                                Text { text: "◈"; font-size: 34px; color: Theme.acc; horizontal-alignment: center; }
                                Text { text: "Coming soon"; font-size: 16px; font-weight: 700; color: Theme.fg; horizontal-alignment: center; }
                                TBtn { label: "Back to Text to Speech"; clicked => { tab = "tts"; } }
                            }
                        }
                    }

                    // ---- player: full-clip waveform that scrubs during playback ----
                    if tab == "tts" && player-active : Rectangle {
                        height: 58px;
                        Rectangle {
                            x: 22px; width: parent.width - 44px; y: 5px; height: parent.height - 10px;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                            border-radius: Theme.rad; background: Theme.card-bg;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                            HorizontalLayout {
                                padding-left: 12px; padding-right: 14px; spacing: 12px;
                                // play / pause / resume
                                Rectangle {
                                    width: 32px; height: 32px; y: parent.height / 2 - 16px;
                                    border-radius: Theme.name == "win95" ? 0px : 16px;
                                    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.acc;
                                    background: (ppb.pressed && Theme.name != "win95") ? Theme.acc-soft : Theme.gen-bg;
                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: ppb.pressed; }
                                    ppb := TouchArea {
                                        clicked => {
                                            if (!player-playing) {
                                                root.play-hist(player-id);
                                            } else if (player-paused) {
                                                player-paused = false;
                                                root.resume();
                                            } else {
                                                player-paused = true;
                                                root.pause();
                                            }
                                        }
                                    }
                                    Text { text: (player-playing && !player-paused) ? "⏸" : "▶"; font-size: 12px; color: Theme.gen-fg;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                                // title + time
                                VerticalLayout {
                                    alignment: center; spacing: 1px; horizontal-stretch: 0;
                                    Text { text: player-title; font-size: 12.5px; font-weight: 700; color: Theme.fg; overflow: elide; }
                                    Text { text: player-time; font-size: 10px; font-family: Theme.mono; color: Theme.dim; }
                                }
                                // scrubbing waveform (DAW-style: mirrored around center; click to seek)
                                Rectangle {
                                    horizontal-stretch: 1; height: 36px;
                                    HorizontalLayout {
                                        spacing: 0px;
                                        for b[i] in player-bars : Rectangle {
                                            horizontal-stretch: 1;
                                            Rectangle {
                                                width: parent.width * 0.7;
                                                height: max(1px, b * 34px);
                                                y: (parent.height - self.height) / 2;
                                                border-radius: 0.5px;
                                                background: i < play-pct * player-bars.length ? Theme.wave : Theme.wave-dim;
                                            }
                                        }
                                    }
                                    seekta := TouchArea {
                                        clicked => {
                                            play-pct = seekta.mouse-x / self.width;
                                            root.seek(player-id, seekta.mouse-x / self.width);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ---- composer (TTS only) ----
                    if tab == "tts" : Rectangle {
                        height: 118px;
                        Rectangle {
                            x: 22px; width: parent.width - 44px; y: 6px; height: parent.height - 24px;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
                            background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                            VerticalLayout {
                                padding: 12px; spacing: 8px;
                                ti := TextInput {
                                    text <=> root.text;
                                    font-size: 14px; color: Theme.fg; wrap: word-wrap;
                                    height: 40px;
                                    single-line: false;
                                }
                                // indeterminate "synthesizing" bar — looping marquee via animation-tick()
                                if synthesizing : Rectangle {
                                    height: 4px; border-radius: 2px; background: Theme.chip-bg; clip: true;
                                    Rectangle {
                                        height: 100%; width: parent.width * 0.35;
                                        border-radius: 2px; background: Theme.gen-bg;
                                        x: -self.width + (parent.width + self.width) * (mod(animation-tick(), 1200ms) / 1200ms);
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: "engine: " + backend; font-size: 10.5px; font-family: Theme.mono;
                                        color: Theme.dim; vertical-alignment: center;
                                    }
                                    Rectangle {}
                                    Text {
                                        text: generating ? "synthesizing…" : "pick a voice, then Generate";
                                        font-size: 10.5px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center;
                                    }
                                    TBtn {
                                        label: generating ? "Stop" : "✦ Generate"; generate: true;
                                        min-width: 130px;
                                        clicked => { if (generating) { root.stop(); } else { root.generate(); } }
                                    }
                                }
                            }
                        }
                    }

                    // ---- footer ----
                    Rectangle {
                        height: 26px; border-width: 1px; border-color: Theme.brd;
                        background: Theme.name == "win95" ? #c0c0c0 : transparent;
                        HorizontalLayout {
                            padding-left: 22px; padding-right: 22px; spacing: 14px;
                            Text { text: "syrinx v0.1.0"; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                            Rectangle {}
                            Text { text: "backend: local · " + backend; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }

    // Win95 raised window frame (outermost 3D border)
    if Theme.name == "win95" : Bevel { x: 0; y: 0; width: root.width; height: root.height; }

    // --- create-voice modal ---
    if cv-open : Rectangle {
        background: #0a0f14d9;  // dimmed backdrop
        TouchArea {}            // swallow clicks to the app behind
        Rectangle {
            width: round(min(860px, root.width - 64px) / 1px) * 1px;
            height: round(min(580px, root.height - 64px) / 1px) * 1px;
            // pixel-align so text/edges render crisp (no subpixel offset)
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            // square corners: a rounded clip forces a blurry offscreen layer
            border-radius: 0px;
            clip: true;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                // header
                Rectangle {
                    height: 46px; background: Theme.tb-bg;
                    HorizontalLayout {
                        padding-left: 18px; padding-right: 12px; spacing: 10px;
                        Text { text: "Create a voice"; font-size: 15px; font-weight: 700; color: Theme.tb-fg; vertical-alignment: center; }
                        Rectangle {}
                        Rectangle {
                            width: 26px; height: 26px; y: parent.height / 2 - 13px; border-radius: Theme.rad;
                            background: xta.has-hover ? Theme.acc-soft : transparent;
                            xta := TouchArea { clicked => { root.cv-cancel(); cv-open = false; } }
                            Text { text: "✕"; font-size: 13px; color: Theme.tb-fg; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
                // body — two columns
                HorizontalLayout {
                    padding: 18px; spacing: 20px;
                    // LEFT: reference audio
                    VerticalLayout {
                        horizontal-stretch: 1; spacing: 10px;
                        Text { text: "REFERENCE AUDIO"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                        HorizontalLayout {
                            spacing: 6px;
                            for t[i] in [
                                { k: "record", l: "Record" }, { k: "upload", l: "Upload" }, { k: "system", l: "System" }
                            ] : Rectangle {
                                horizontal-stretch: 1; height: 30px; border-radius: Theme.rad;
                                border-width: Theme.name == "win95" ? 0px : 1px;
                                border-color: cv-mode == t.k ? Theme.acc : Theme.btn-brd;
                                background: cv-mode == t.k ? Theme.acc-soft : Theme.btn-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: cv-mode == t.k; }
                                TouchArea { clicked => { cv-mode = t.k; } }
                                Text {
                                    text: t.l; font-size: 11.5px; font-family: Theme.font;
                                    color: cv-mode == t.k ? Theme.acc : Theme.fg;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                        // capture action area
                        Rectangle {
                            height: 92px; border-radius: Theme.rad;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                            background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                            VerticalLayout {
                                padding: 12px; spacing: 8px; alignment: center;
                                HorizontalLayout {
                                    alignment: center;
                                    TBtn {
                                        label: cv-mode == "upload" ? "Choose file…" : (cv-recording ? "■ Stop" : "● Record");
                                        generate: cv-recording;
                                        min-width: 150px;
                                        clicked => {
                                            if (cv-mode == "upload") { root.cv-pick-file(); }
                                            else if (cv-recording) { root.cv-stop-record(); }
                                            else { root.cv-start-record(); }
                                        }
                                    }
                                }
                                Text {
                                    text: cv-sample-label != "" ? cv-sample-label
                                        : (cv-mode == "upload" ? "Pick a .wav / .mp3 / .flac clip"
                                        : cv-mode == "system" ? "System audio — use speaker/HDMI output (Bluetooth can't be tapped)"
                                        : "Record 5–30s of clear speech");
                                    font-size: 11px; font-family: Theme.mono; color: Theme.dim;
                                    horizontal-alignment: center; wrap: word-wrap;
                                }
                            }
                        }
                        // transcript
                        HorizontalLayout {
                            spacing: 10px;
                            Text { text: "TRANSCRIPT"; font-size: 11px; font-weight: 700; color: Theme.dim; vertical-alignment: center; }
                            Rectangle {}
                            TBtn { label: cv-transcribing ? "Transcribing…" : "Transcribe"; clicked => { root.cv-transcribe(); } }
                        }
                        Rectangle {
                            vertical-stretch: 1;
                            background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
                            clip: true;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                            if cv-transcript == "" : Text {
                                x: 10px; y: 8px; text: "What the reference clip says (required for cloning).";
                                font-size: 12px; color: Theme.dim; opacity: 0.6; font-family: Theme.font;
                            }
                            TextInput {
                                x: 10px; y: 8px; width: parent.width - 20px; height: parent.height - 16px;
                                text <=> cv-transcript; font-size: 13px; color: Theme.fg; font-family: Theme.font;
                                wrap: word-wrap; single-line: false;
                            }
                        }
                    }
                    // RIGHT: voice details
                    VerticalLayout {
                        horizontal-stretch: 1; spacing: 12px;
                        Text { text: "VOICE DETAILS"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                        LabeledInput { label: "NAME"; placeholder: "e.g. Kestrel"; value <=> cv-name; }
                        LabeledInput { label: "DESCRIPTION"; placeholder: "Short note about this voice"; value <=> cv-desc; }
                        LabeledInput { label: "PERSONALITY"; placeholder: "Optional character / style prompt"; multiline: true; value <=> cv-personality; }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "LANGUAGE"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                            ThemedDropdown {
                                model: ["English", "Japanese", "Chinese", "German", "Spanish", "French", "Italian", "Portuguese"];
                                current-index: 0;
                                selected(i) => { cv-language = ["en", "ja", "zh", "de", "es", "fr", "it", "pt"][i]; }
                            }
                        }
                        Rectangle {}
                        Text {
                            text: "Cloned voices synthesize with the Qwen engine.";
                            font-size: 10.5px; font-family: Theme.mono; color: Theme.dim; wrap: word-wrap;
                        }
                    }
                }
                // footer
                Rectangle {
                    height: 56px;
                    Rectangle { x: 0; y: 0; width: 100%; height: 1px; background: Theme.brd; }
                    HorizontalLayout {
                        padding-left: 18px; padding-right: 18px; spacing: 10px; alignment: end;
                        TBtn { label: "Cancel"; clicked => { root.cv-cancel(); cv-open = false; } }
                        TBtn {
                            label: cv-creating ? "Creating…" : "✦ Create voice"; generate: true; min-width: 150px;
                            clicked => { root.cv-create(); }
                        }
                    }
                }
            }
        }
    }
}

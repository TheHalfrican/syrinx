// Syrinx — main window. Themed shell + TTS workspace, wired to the engine.
import { Theme } from "theme.slint";
// re-export so Rust can restore the persisted theme at startup
export { Theme }
import { ScrollView } from "std-widgets.slint";

export struct VoiceItem {
    id: string, name: string, desc: string, lang: string, kind: string, has-personality: bool,
    // avatar: pre-baked thumbnail (crop applied + downscaled in Rust — GPU
    // minification of full-size photos pixelates). mode "circle" | "panel".
    avatar: image, avatar-mode: string, has-avatar: bool,
}
export struct HistItem { id: string, voice: string, meta: string, text: string, starred: bool }
export struct CaptureItem { id: string, text: string, date: string }
export struct SourceClipItem { id: string, name: string, meta: string }
export struct LibItem {
    id: string, title: string, meta: string, text: string,
    starred: bool, tags: string,  // tags = comma-joined, editable as typed
}
export struct ProfileRow {
    id: string, name: string, desc: string, lang: string, engine: string,
    samples: string, gens: string, avatar: image, has-avatar: bool,
}
export struct SampleRow { id: string, text: string }
export struct FxPresetItem { id: string, name: string, builtin: bool }
export struct FxRowItem { label: string, enabled: bool, expanded: bool }
export struct FxParamItem { label: string, value-text: string, norm: float }
export struct ModelItem {
    id: string, display: string, size-label: string, description: string,
    downloaded: bool, downloading: bool, active: bool, supported: bool,
    warning: string, progress: float,
}

// --- Win95 3D bevel overlay (transparent center; draws a doubled 2px edge) ---
// raised (default) = light top/left, dark bottom/right; sunken flips it (fields, pressed).
component Bevel inherits Rectangle {
    in property <bool> sunken: false;
    property <color> tl1: sunken ? #808080 : #ffffff;   // outer top-left
    property <color> br1: sunken ? #ffffff : #404040;   // outer bottom-right
    property <color> tl2: sunken ? #404040 : #d4d0c8;   // inner top-left
    property <color> br2: sunken ? #d4d0c8 : #808080;   // inner bottom-right
    // outer edge
    Rectangle { x: 0; y: 0; width: parent.width; height: 1px; background: tl1; }
    Rectangle { x: 0; y: 0; width: 1px; height: parent.height; background: tl1; }
    Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: br1; }
    Rectangle { x: parent.width - 1px; y: 0; width: 1px; height: parent.height; background: br1; }
    // inner edge (inset 1px)
    Rectangle { x: 1px; y: 1px; width: parent.width - 2px; height: 1px; background: tl2; }
    Rectangle { x: 1px; y: 1px; width: 1px; height: parent.height - 2px; background: tl2; }
    Rectangle { x: 1px; y: parent.height - 2px; width: parent.width - 2px; height: 1px; background: br2; }
    Rectangle { x: parent.width - 2px; y: 1px; width: 1px; height: parent.height - 2px; background: br2; }
}

// --- sidebar nav icon ---
component NavIcon inherits Rectangle {
    in property <string> glyph;
    in property <bool> active;
    callback clicked;
    // The rail renders under the main panel, so tooltips can't be drawn here —
    // report hover + window-y and let AppWindow's overlay draw them on top.
    callback hover-changed(bool, length);
    width: 42px; height: 42px; border-radius: Theme.rad;
    background: active ? Theme.acc : (ta.has-hover ? Theme.acc-soft : transparent);
    ta := TouchArea {
        clicked => { root.clicked(); }
        changed has-hover => { root.hover-changed(self.has-hover, root.absolute-position.y); }
    }
    Text {
        text: glyph; font-size: 18px;
        color: active ? Theme.acc-fg : Theme.dim;
        horizontal-alignment: center; vertical-alignment: center;
    }
}

// --- themed button (variant: generate = accent) ---
component TBtn inherits Rectangle {
    in property <string> label;
    in property <bool> generate;
    callback clicked;
    property <bool> win95: Theme.name == "win95";
    height: 30px;
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1px;
    border-color: generate ? Theme.acc : Theme.btn-brd;
    background: win95 ? (generate ? Theme.gen-bg : Theme.btn-bg)
             : (ta2.pressed ? Theme.acc-soft : (generate ? Theme.gen-bg : Theme.btn-bg));
    horizontal-stretch: 0;
    ta2 := TouchArea { clicked => { root.clicked(); } }
    HorizontalLayout {
        padding-left: 13px; padding-right: 13px;
        Text {
            text: label; font-size: 12px;
            font-weight: generate ? 700 : 500;
            font-family: Theme.font;
            color: generate ? Theme.gen-fg : Theme.btn-fg;
            vertical-alignment: center; horizontal-alignment: center;
        }
    }
    if win95 : Bevel { width: 100%; height: 100%; sunken: ta2.pressed; }
}

component Chip inherits Rectangle {
    in property <string> label;
    background: Theme.chip-bg; border-radius: Theme.rad;
    height: 18px;
    HorizontalLayout {
        padding-left: 7px; padding-right: 7px;
        Text { text: label; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
    }
}

// --- small round icon button (Voicebox-style composer / card actions) ---
component IconBtn inherits Rectangle {
    in property <string> glyph;
    in property <string> tip;         // hover tooltip ('95 pale-yellow on win95)
    in property <bool> accent;        // filled accent (the Generate button)
    in property <bool> active;        // toggled-on state (persona, loop)
    in property <bool> enabled: true;
    in property <length> size: 30px;
    in property <length> glyph-size: 13px;
    callback clicked;
    property <bool> win95: Theme.name == "win95";
    width: size; height: size;
    border-radius: win95 ? 0px : size / 2;
    border-width: win95 ? 0px : 1px;
    border-color: (accent || active) ? Theme.acc : Theme.btn-brd;
    background: accent ? Theme.gen-bg
             : active ? Theme.acc-soft
             : ((ib.has-hover && enabled) ? Theme.acc-soft : Theme.btn-bg);
    opacity: enabled ? 1.0 : 0.45;
    if win95 : Bevel { width: 100%; height: 100%; sunken: ib.pressed || active; }
    ib := TouchArea { enabled: root.enabled; clicked => { root.clicked(); } }
    Text {
        text: glyph; font-size: glyph-size;
        color: accent ? Theme.gen-fg : (active ? Theme.acc : Theme.btn-fg);
        horizontal-alignment: center; vertical-alignment: center;
    }
    // tooltip — right-aligned above the button so card clipping can't cut it;
    // fades in after a hover delay (state transition below), hides instantly
    tipbox := Rectangle {
        x: root.width - self.width;
        y: -self.height - 5px;
        height: 20px;
        width: tl.preferred-width + 14px;
        opacity: 0;
        background: win95 ? #ffffe1 : #10151be6;
        border-width: 1px; border-color: win95 ? #000000 : #ffffff33;
        border-radius: win95 ? 0px : 4px;
        tl := Text {
            x: 7px; height: 100%;
            text: tip; font-size: 10px; font-family: Theme.font;
            color: win95 ? #000000 : #ffffff;
            vertical-alignment: center;
        }
    }
    states [
        tip-shown when ib.has-hover && tip != "" : {
            tipbox.opacity: 1;
            in { animate tipbox.opacity { duration: 100ms; delay: 1200ms; } }
            out { animate tipbox.opacity { duration: 80ms; } }
        }
    ]
}

component VoiceCard inherits Rectangle {
    in property <VoiceItem> v;
    in property <string> selected;
    property <bool> active: v.id == selected;
    property <bool> win95: Theme.name == "win95";
    callback clicked;
    callback export-clicked;
    callback edit-clicked;
    callback delete-clicked;
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1.5px;
    border-color: active ? Theme.acc : (ta.has-hover ? Theme.acc : Theme.brd);
    background: Theme.card-bg;
    // no clip: rounded clip forces a blurry offscreen layer (content is padded anyway)
    property <bool> panel: v.avatar-mode == "panel" && v.has-avatar;
    property <bool> circ: v.avatar-mode != "panel" && v.has-avatar;
    ta := TouchArea { clicked => { root.clicked(); } }
    if win95 : Bevel { width: 100%; height: 100%; sunken: active; }
    HorizontalLayout {
        // LEFT: card content (full width unless a panel avatar claims a third)
        VerticalLayout {
            horizontal-stretch: 1;
            padding: 13px; spacing: 4px;
            HorizontalLayout {
                spacing: 10px;
                VerticalLayout {
                    horizontal-stretch: 1; spacing: 4px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: v.name; font-size: 14px; font-weight: 700; color: Theme.fg; overflow: elide; vertical-alignment: center; }
                        if active : Rectangle {
                            background: Theme.acc; border-radius: 9px; height: 18px;
                            y: 1px;
                            HorizontalLayout {
                                padding-left: 7px; padding-right: 7px;
                                Text { text: "ACTIVE"; font-size: 9px; font-weight: 700; color: Theme.acc-fg; vertical-alignment: center; }
                            }
                        }
                        Rectangle {}
                    }
                    Text { text: v.desc; font-size: 11.5px; color: Theme.dim; wrap: word-wrap; }
                }
                // big circular avatar, top-right of the content area
                if circ : VerticalLayout {
                    alignment: start;
                    Rectangle {
                        width: 96px; height: 96px; border-radius: 48px;
                        border-width: 1px; border-color: Theme.brd;
                        clip: true;
                        Image {
                            width: 100%; height: 100%;
                            source: v.avatar;
                            image-fit: cover;
                        }
                    }
                }
            }
            Rectangle {}  // flex spacer — push chips to the bottom
            HorizontalLayout {
                spacing: 6px;
                Chip { label: v.lang; }
                Chip { label: v.kind; }
                Rectangle {}
                // Voicebox-style card actions: export / edit / delete
                IconBtn { size: 24px; glyph-size: 11px; glyph: "⇩"; tip: "Export voice"; clicked => { root.export-clicked(); } }
                IconBtn { size: 24px; glyph-size: 11px; glyph: "✎"; tip: "Edit voice"; clicked => { root.edit-clicked(); } }
                IconBtn { size: 24px; glyph-size: 11px; glyph: "✕"; tip: "Delete voice"; clicked => { root.delete-clicked(); } }
            }
        }
        // RIGHT: panel avatar behind a divider
        if panel : Rectangle { width: 1px; background: Theme.brd; }
        if panel : Rectangle {
            // inset so the image stops at the card's border/bevel highlight
            // instead of painting over it
            property <length> inset: root.win95 ? 2px : root.border-width;
            // pin the panel to the crop dialog's 3:5 viewport aspect so the
            // crop is WYSIWYG at any window size (a proportional 40% width
            // rendered near-square on wide windows and cover-cropped the
            // top/bottom off). The 45% cap only bites on narrow cards and
            // trims the sides, never faces.
            width: min(root.width * 0.45, (root.height - 2 * self.inset) * 0.6);
            Rectangle {
                x: 0; y: parent.inset;
                width: parent.width - parent.inset;
                height: parent.height - 2 * parent.inset;
                clip: true;
                border-top-right-radius: max(0px, Theme.rad - parent.inset);
                border-bottom-right-radius: max(0px, Theme.rad - parent.inset);
                Image {
                    width: 100%; height: 100%;
                    source: v.avatar;
                    image-fit: cover;
                }
            }
        }
    }
}

// --- themed dropdown (replaces the std ComboBox so it matches every skin) ---
component ThemedDropdown inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    in property <bool> up: false;   // open the list above (for bottom-anchored rows)
    callback selected(int);
    property <bool> win95: Theme.name == "win95";
    property <length> list-height: min(model.length * 26px + 4px, 210px);
    height: 30px;
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1px;
    border-color: Theme.btn-brd;
    background: win95 ? #ffffff : Theme.card-bg;
    if win95 : Bevel { width: 100%; height: 100%; sunken: true; }
    HorizontalLayout {
        padding-left: 10px; padding-right: 6px; spacing: 4px;
        Text {
            text: model[current-index]; font-size: 12px; color: Theme.fg; font-family: Theme.font;
            vertical-alignment: center; overflow: elide; horizontal-stretch: 1;
        }
        Text { text: "▾"; font-size: 10px; color: Theme.dim; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { popup.show(); } }
    popup := PopupWindow {
        x: 0; y: up ? -list-height - 2px : root.height + 2px;
        width: root.width;
        height: list-height;
        close-policy: close-on-click-outside;
        Rectangle {
            background: win95 ? #ffffff : Theme.card-bg;
            border-width: win95 ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
            if win95 : Bevel { width: 100%; height: 100%; }
            ScrollView {
                VerticalLayout {
                    padding: 2px;
                    for opt[i] in model : Rectangle {
                        height: 26px;
                        background: (i == current-index || ita.has-hover) ? Theme.acc-soft : transparent;
                        ita := TouchArea {
                            clicked => { root.current-index = i; root.selected(i); popup.close(); }
                        }
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 8px;
                            Text {
                                text: opt; font-size: 12px; color: Theme.fg; font-family: Theme.font;
                                vertical-alignment: center; overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}

// --- "Kokoro Defaults" card: bundled presets collapsed behind a dropdown ---
component KokoroCard inherits Rectangle {
    in property <string> selected;
    in property <bool> active;
    in property <[string]> names;
    in property <[string]> ids;
    in-out property <int> current-index: 0;
    callback pick(string);
    property <bool> win95: Theme.name == "win95";
    border-radius: Theme.rad;
    border-width: win95 ? 0px : 1.5px;
    border-color: active ? Theme.acc : (cta.has-hover ? Theme.acc : Theme.brd);
    background: Theme.card-bg;
    if win95 : Bevel { width: 100%; height: 100%; sunken: active; }
    // click anywhere but the dropdown to (re)select the current preset
    cta := TouchArea { clicked => { root.pick(ids[dd.current-index]); } }
    VerticalLayout {
        padding: 13px; spacing: 6px;
        HorizontalLayout {
            spacing: 8px;
            Text { text: "Kokoro Defaults"; font-size: 14px; font-weight: 700; color: Theme.fg; }
            Rectangle {}
            if active : Rectangle {
                background: Theme.acc; border-radius: 9px;
                HorizontalLayout {
                    padding-left: 7px; padding-right: 7px;
                    Text { text: "ACTIVE"; font-size: 9px; font-weight: 700; color: Theme.acc-fg; vertical-alignment: center; }
                }
            }
        }
        Text { text: names.length + " bundled preset voices"; font-size: 11.5px; color: Theme.dim; }
        Rectangle {}  // flex spacer
        dd := ThemedDropdown {
            model: names;
            current-index <=> root.current-index;
            selected(i) => { root.pick(ids[i]); }
        }
    }
}

// --- a single row-menu entry ---
component RowMenuItem inherits Rectangle {
    in property <string> label;
    in property <color> tint: Theme.fg;
    in property <bool> enabled: true;
    callback chosen();
    height: 28px; border-radius: Theme.rad;
    background: (enabled && mi.has-hover) ? Theme.acc-soft : transparent;
    mi := TouchArea { enabled: root.enabled; clicked => { root.chosen(); } }
    HorizontalLayout {
        padding-left: 10px; padding-right: 10px;
        Text {
            text: label; font-size: 12px; font-family: Theme.font; vertical-alignment: center;
            color: enabled ? tint : Theme.dim; opacity: enabled ? 1.0 : 0.5;
        }
    }
}

// --- per-row 3-dot menu (history actions) ---
component RowMenu inherits Rectangle {
    callback play();
    callback regen();
    callback export-audio();
    callback export-package();
    callback apply-effects();
    callback del();
    property <bool> win95: Theme.name == "win95";
    width: 24px; height: 24px; border-radius: Theme.rad;
    background: ta.has-hover ? Theme.acc-soft : transparent;
    ta := TouchArea { clicked => { pop.show(); } }
    Text { text: "⋮"; font-size: 16px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
    pop := PopupWindow {
        x: root.width - 176px; y: root.height + 2px;
        width: 176px; height: 190px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: win95 ? #ffffff : Theme.card-bg;
            border-width: win95 ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
            if win95 : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                padding: 3px;
                RowMenuItem { label: "Play"; chosen => { root.play(); pop.close(); } }
                RowMenuItem { label: "Regenerate"; chosen => { root.regen(); pop.close(); } }
                RowMenuItem { label: "Export audio"; chosen => { root.export-audio(); pop.close(); } }
                RowMenuItem { label: "Export package"; chosen => { root.export-package(); pop.close(); } }
                RowMenuItem { label: "Apply effects"; chosen => { root.apply-effects(); pop.close(); } }
                Rectangle { height: 1px; background: Theme.brd; }
                RowMenuItem { label: "Delete"; tint: #cc3b3b; chosen => { root.del(); pop.close(); } }
            }
        }
    }
}

// --- labeled text field (create-voice modal) ---
component LabeledInput inherits VerticalLayout {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> multiline: false;
    // overridable for placements on dark backdrops (vc view on Aero)
    in property <color> label-color: Theme.dim;
    in-out property <string> value;
    spacing: 4px;
    Text { text: label; font-size: 11px; font-weight: 700; color: label-color; }
    Rectangle {
        height: multiline ? 60px : 30px;
        background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
        border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
        clip: true;
        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
        if value == "" : Text {
            x: 9px; y: 7px; text: placeholder; font-size: 12.5px; color: Theme.dim; opacity: 0.6;
            font-family: Theme.font;
        }
        property <length> ctx-x;
        property <length> ctx-y;
        // under the input: right-clicks only (left = caret/selection)
        lita := TouchArea {
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                    ctx-x = lita.mouse-x;
                    ctx-y = lita.mouse-y;
                    limenu.show();
                }
            }
        }
        // scrolls when the text outgrows the box: the viewport
        // must be sized explicitly or ScrollView never scrolls
        lisv := ScrollView {
            x: 9px; y: 6px; width: parent.width - 18px; height: parent.height - 12px;
            viewport-width: multiline ? self.visible-width : max(self.visible-width, liti.preferred-width);
            viewport-height: multiline ? max(self.visible-height, liti.preferred-height) : self.visible-height;
            liti := TextInput {
                page-height: lisv.visible-height;
                text <=> value; font-size: 13px; color: Theme.fg; font-family: Theme.font;
                wrap: multiline ? word-wrap : no-wrap; single-line: !multiline;
                // keep the caret in view while typing (both axes: multiline
                // scrolls vertically, single-line fields pan horizontally)
                cursor-position-changed(cpos) => {
                    if (cpos.y + lisv.viewport-y < 0px) {
                        lisv.viewport-y = min(0px, max(lisv.visible-height - self.height, -cpos.y));
                    } else if (cpos.y + lisv.viewport-y > lisv.visible-height - 20px) {
                        lisv.viewport-y = min(0px, max(lisv.visible-height - self.height, lisv.visible-height - cpos.y - 20px));
                    }
                    if (cpos.x + lisv.viewport-x < 0px) {
                        lisv.viewport-x = min(0px, max(lisv.visible-width - self.width, -cpos.x));
                    } else if (cpos.x + lisv.viewport-x > lisv.visible-width - 12px) {
                        lisv.viewport-x = min(0px, max(lisv.visible-width - self.width, lisv.visible-width - cpos.x - 12px));
                    }
                }
            }
        }
        limenu := PopupWindow {
            x: parent.ctx-x; y: parent.ctx-y;
            width: 150px; height: 120px;
            close-policy: close-on-click-outside;
            Rectangle {
                background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                border-width: Theme.name == "win95" ? 0px : 1px;
                border-color: Theme.brd; border-radius: Theme.rad;
                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                VerticalLayout {
                    padding: 3px;
                    RowMenuItem { label: "Cut"; chosen => { liti.cut(); limenu.close(); } }
                    RowMenuItem { label: "Copy"; chosen => { liti.copy(); limenu.close(); } }
                    RowMenuItem { label: "Paste"; chosen => { liti.paste(); limenu.close(); } }
                    RowMenuItem { label: "Select all"; chosen => { liti.select-all(); limenu.close(); } }
                }
            }
        }
    }
}

// --- a model catalog row (Models tab) ---
component ModelRow inherits Rectangle {
    in property <ModelItem> m;
    // false for conversion engines: the ⇄ tab's dropdown picks per
    // conversion, so there is no "Use"/active concept to offer
    in property <bool> selectable: true;
    callback download();
    callback del();
    callback activate();
    height: 64px;
    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
    background: Theme.card-bg;
    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
    HorizontalLayout {
        padding-left: 14px; padding-right: 12px; spacing: 12px;
        Rectangle {
            width: 10px; height: 10px; y: parent.height / 2 - 5px; border-radius: 5px;
            background: m.active ? Theme.acc : (m.downloaded ? #3ca35a : (m.downloading ? Theme.wave : Theme.brd));
        }
        VerticalLayout {
            alignment: center; spacing: 2px; horizontal-stretch: 1;
            HorizontalLayout {
                spacing: 8px;
                Text { text: m.display; font-size: 13px; font-weight: 700; color: Theme.fg; vertical-alignment: center; }
                Text { text: m.size-label; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                if m.active : Rectangle {
                    background: Theme.acc; border-radius: 8px;
                    HorizontalLayout { padding-left: 6px; padding-right: 6px;
                        Text { text: "ACTIVE"; font-size: 8.5px; font-weight: 700; color: Theme.acc-fg; vertical-alignment: center; } }
                }
                if !m.supported : Rectangle {
                    background: Theme.chip-bg; border-radius: 8px;
                    HorizontalLayout { padding-left: 6px; padding-right: 6px;
                        Text { text: "engine soon"; font-size: 8.5px; color: Theme.dim; vertical-alignment: center; } }
                }
                Rectangle {}
            }
            Text { text: m.description; font-size: 10.5px; color: Theme.dim; overflow: elide; }
            if m.warning != "" : Text { text: "⚠ " + m.warning; font-size: 9.5px; color: #d9922b; overflow: elide; }
        }
        Rectangle {
            width: 156px;
            if m.downloading : VerticalLayout {
                alignment: center; spacing: 5px;
                Text { text: "downloading…"; font-size: 9.5px; font-family: Theme.mono; color: Theme.dim; horizontal-alignment: center; }
                Rectangle {
                    height: 6px; border-radius: 3px; background: Theme.chip-bg;
                    Rectangle { x: 0; width: parent.width * m.progress; height: 100%; border-radius: 3px; background: Theme.gen-bg; }
                }
            }
            if !m.downloading : HorizontalLayout {
                alignment: end; spacing: 6px;
                if m.downloaded && m.supported && !m.active && selectable : TBtn { label: "Use"; clicked => { root.activate(); } }
                if m.downloaded : TBtn { label: "Delete"; clicked => { root.del(); } }
                if !m.downloaded && m.supported : TBtn { label: "Download"; generate: true; clicked => { root.download(); } }
                if !m.downloaded && !m.supported : Text { text: "no backend yet"; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
            }
        }
    }
}

// --- shared bottom player bar (TTS view + Library) ---
component PlayerBar inherits Rectangle {
    in property <string> p-id;
    in property <string> p-title;
    in property <string> p-time;
    in property <[float]> p-bars;
    in property <bool> p-playing;
    in-out property <bool> p-paused;
    in-out property <bool> p-loop;
    in-out property <float> p-volume;
    in-out property <float> p-pct;
    callback play();
    callback pause();
    callback resume();
    callback seek(float);
    callback toggle-loop(bool);
    callback set-volume(float);
    callback trim();   // ✂ — only offered for history clips (p-id != "")
    callback close();
    height: 52px;
    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
    border-radius: Theme.rad; background: Theme.card-bg;
    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
    HorizontalLayout {
        padding-left: 10px; padding-right: 10px; spacing: 10px;
        // play / pause / resume
        Rectangle {
            width: 30px; height: 30px; y: parent.height / 2 - 15px;
            border-radius: Theme.name == "win95" ? 0px : 15px;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.acc;
            background: (ppb.pressed && Theme.name != "win95") ? Theme.acc-soft : Theme.gen-bg;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: ppb.pressed; }
            ppb := TouchArea {
                clicked => {
                    if (!p-playing) {
                        root.play();
                    } else if (p-paused) {
                        p-paused = false;
                        root.resume();
                    } else {
                        p-paused = true;
                        root.pause();
                    }
                }
            }
            Text { text: (p-playing && !p-paused) ? "⏸" : "▶"; font-size: 11px; color: Theme.gen-fg;
                   horizontal-alignment: center; vertical-alignment: center; }
        }
        // title + time
        VerticalLayout {
            alignment: center; spacing: 1px; horizontal-stretch: 0;
            Text { text: p-title; font-size: 11.5px; font-weight: 700; color: Theme.fg; overflow: elide; }
            Text { text: p-time; font-size: 9.5px; font-family: Theme.mono; color: Theme.dim; }
        }
        // scrubbing waveform (mirrored around center; click or
        // drag to seek) — wavesurfer-style pills: 2:1 bar/gap,
        // fully rounded ends
        Rectangle {
            horizontal-stretch: 1; height: 32px; y: parent.height / 2 - 16px;
            HorizontalLayout {
                spacing: 0px;
                for b[i] in p-bars : Rectangle {
                    horizontal-stretch: 1;
                    Rectangle {
                        width: parent.width * 0.66;
                        height: max(2px, b * 30px);
                        y: (parent.height - self.height) / 2;
                        border-radius: self.width / 2;
                        background: i < p-pct * p-bars.length ? Theme.wave : Theme.wave-dim;
                    }
                }
            }
            seekta := TouchArea {
                moved => {
                    if (self.pressed) {
                        p-pct = max(0.0, min(1.0, seekta.mouse-x / self.width));
                    }
                }
                clicked => {
                    p-pct = max(0.0, min(1.0, seekta.mouse-x / self.width));
                    root.seek(p-pct);
                }
            }
        }
        // loop toggle (re-plays the clip when it ends)
        VerticalLayout {
            alignment: center;
            IconBtn {
                size: 26px; glyph-size: 12px; glyph: "⟳"; active: p-loop;
                tip: p-loop ? "Looping" : "Loop";
                clicked => { p-loop = !p-loop; root.toggle-loop(p-loop); }
            }
        }
        // trim — history clips only (file auditions have no row to keep)
        if p-id != "" : VerticalLayout {
            alignment: center;
            IconBtn {
                size: 26px; glyph-size: 12px; glyph: "✂";
                tip: "Trim clip";
                clicked => { root.trim(); }
            }
        }
        // volume: mute toggle + slider
        VerticalLayout {
            alignment: center;
            IconBtn {
                size: 26px; glyph-size: 12px;
                glyph: p-volume == 0.0 ? "∅" : "♪";
                tip: p-volume == 0.0 ? "Unmute" : "Mute";
                clicked => {
                    p-volume = p-volume == 0.0 ? 1.0 : 0.0;
                    root.set-volume(p-volume);
                }
            }
        }
        Rectangle {
            width: 64px;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    height: 5px; border-radius: 2.5px; background: Theme.chip-bg;
                    Rectangle {
                        x: 0; y: 0; height: 100%; border-radius: 2.5px;
                        width: parent.width * p-volume;
                        background: Theme.acc;
                    }
                }
            }
            vta := TouchArea {
                clicked => {
                    p-volume = max(0.0, min(1.0, vta.mouse-x / self.width));
                    root.set-volume(p-volume);
                }
                moved => {
                    if (vta.pressed) {
                        p-volume = max(0.0, min(1.0, vta.mouse-x / self.width));
                        root.set-volume(p-volume);
                    }
                }
            }
        }
        // close (hides the bar; playback keeps its state)
        VerticalLayout {
            alignment: center;
            IconBtn {
                size: 26px; glyph-size: 11px; glyph: "✕"; tip: "Hide player";
                clicked => { root.close(); }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Syrinx";
    preferred-width: 1180px;
    preferred-height: 760px;
    background: Theme.win-bg;
    default-font-family: Theme.font;

    // --- state exposed to Rust ---
    in property <[VoiceItem]> voices;   // grid items: [Kokoro card, user voices…, spacers]
    in property <[string]> kokoro-names;
    in property <[string]> kokoro-ids;
    in-out property <bool> kokoro-active: true;
    in-out property <int> kokoro-index: 0;
    in property <[HistItem]> history;
    in-out property <string> selected-voice;
    in-out property <string> text;
    in property <bool> generating;
    in property <float> level;
    in property <string> backend: "cpu";
    in property <bool> selected-has-personality;
    in property <bool> llm-busy;
    // --- composer (Voicebox-style) ---
    in property <string> selected-voice-name;
    in property <[string]> composer-langs;
    in-out property <int> composer-lang-index: 0;
    in property <[string]> composer-engines;
    in-out property <int> composer-engine-index: 0;
    in property <[string]> composer-effects: ["No effects"];
    in-out property <int> composer-effect-index: 0;
    in-out property <int> composer-style-index: 0;  // delivery direction (index into app-side STYLES)
    in property <bool> style-supported: false;      // selected voice's engine honors instructs
    callback pick-style(int);
    in-out property <bool> persona-on: false;   // "speak in character" toggle
    in-out property <string> gen-error: "";     // last generation failure (cleared on Generate)
    // --- navbar tooltip overlay (drawn window-level, above the main panel) ---
    in-out property <string> nav-tip: "";
    in-out property <length> nav-tip-y: 0px;
    // --- transcription view ---
    in-out property <string> tr-text;
    in property <bool> tr-recording;
    in property <string> tr-rec-mode: "mic";   // which source is live
    in property <bool> tr-busy;                // transcribing or refining
    in property <string> tr-status;
    in property <[CaptureItem]> captures;      // persisted transcripts (text only)
    in-out property <string> tr-capture-id;    // loaded capture ("" = unsaved)
    // --- voice changer (⇄ vc) view ---
    in property <bool> vc-recording;
    in property <string> vc-rec-mode: "mic";   // which source is live
    in property <bool> vc-busy;                // conversion in flight
    in property <string> vc-status;
    in property <string> vc-source-label;      // armed source description
    in property <bool> vc-has-source: false;
    in property <string> vc-error: "";
    in property <[string]> vc-voice-names: []; // cloned profiles with samples
    in-out property <int> vc-voice-index: 0;
    // conversion models — ids resolved in Rust (VC_ENGINE_IDS / VC_MUSIC_ENGINE_IDS)
    in property <[string]> vc-engine-names: ["Chatterbox VC", "Seed-VC", "Vevo-Timbre"];
    in-out property <int> vc-engine-index: 0;
    in-out property <string> vc-mode: "speech";  // "speech" | "music"
    // music mode = singing-capable engines only (Vevo2 joins here)
    in property <[string]> vc-music-engine-names: ["Seed-VC (singing)", "Vevo2 (singing)"];
    in-out property <int> vc-music-engine-index: 0;
    in-out property <int> vc-octave-index: 2;    // 0..4 → −2..+2 octaves (♫ register shift)
    in property <[SourceClipItem]> vc-clips;   // saved source clips (rail)
    // conversion results (right rail), split by mode — the ♫ title marker
    // decides which list a row lands in
    in property <[HistItem]> vc-history-speech;
    in property <[HistItem]> vc-history-music;
    in property <string> vc-transcript;        // auto-transcribed source words
    in property <bool> vc-transcribing;
    in property <string> vc-armed-id: "";      // saved clip armed as source ("" = scratch/import)
    in property <bool> vc-armed-saved: false;  // hides "Save clip" when already stored
    in property <string> vc-audition-id: "";   // clip id or "scratch" while auditioning
    in-out property <string> vc-clip-name;     // save-as name input
    in-out property <string> vc-result-name;   // history label for the conversion
    // --- delete-voice confirm ---
    in-out property <string> del-id: "";
    in-out property <string> del-name: "";
    // --- apply-effects-to-history dialog ---
    in-out property <string> fx-id: "";
    in-out property <string> fx-voice: "";
    in-out property <int> fx-index: 0;
    // --- effects chain editor modal ---
    in-out property <bool> fxe-open: false;
    in property <[FxPresetItem]> fxe-presets;
    in property <int> fxe-preset-index: -1;    // highlighted preset (-1 = new chain)
    in property <[FxRowItem]> fxe-chain;
    in property <[FxParamItem]> fxe-params;    // params of the expanded row only
    in-out property <string> fxe-name;
    in-out property <string> fxe-desc;
    in property <bool> fxe-builtin: false;     // loaded from a builtin (save = copy)
    in property <[string]> fxe-add-model: ["＋ Add effect…"];
    in property <string> fxe-status;
    in property <bool> fxe-can-preview: false;
    in property <bool> fxe-can-delete: false;
    callback fxe-show();
    callback fxe-load(int);
    callback fxe-new();
    callback fxe-add-effect(int);   // index into the effect defs
    callback fxe-remove(int);
    callback fxe-toggle(int);
    callback fxe-move(int, int);    // row, direction (-1 up / +1 down)
    callback fxe-expand(int);
    callback fxe-param(int, float); // param row, normalized 0..1
    callback fxe-save();
    callback fxe-delete();
    callback fxe-preview();
    // --- models tab ---
    in property <[ModelItem]> voice-models;
    in property <[ModelItem]> stt-models;
    in property <[ModelItem]> llm-models;
    in property <[ModelItem]> vc-conv-models;  // ⇄ conversion engines (no "Use")
    in property <string> hardware-line;
    // --- player (full-clip waveform + scrub) ---
    in property <bool> player-active;
    in property <[float]> player-bars;
    in-out property <float> play-pct;
    in property <string> player-title;
    in property <string> player-id;
    in property <string> player-time;
    in property <bool> player-playing;
    in-out property <bool> player-paused;
    in-out property <bool> player-loop: false;
    in-out property <float> player-volume: 1.0;
    in-out property <bool> player-active-visible: true;  // X button hides the bar
    in property <bool> synthesizing;
    // --- create-voice modal ---
    in-out property <bool> cv-open: false;
    in-out property <string> cv-mode: "record";   // record | upload | system
    in property <bool> cv-recording;
    in property <bool> cv-transcribing;
    in property <bool> cv-creating;
    in-out property <string> cv-error: "";  // last create/edit failure, shown in the modal footer
    in property <string> cv-sample-label;
    in-out property <string> cv-name;
    in-out property <string> cv-desc;
    in-out property <string> cv-personality;
    in-out property <string> cv-transcript;
    in-out property <string> cv-language: "en";
    in-out property <int> cv-lang-index: 0;
    in-out property <string> cv-edit-id: "";   // non-empty = the modal edits this profile
    in property <[string]> cv-model-options: ["Follow active model"];
    in-out property <int> cv-model-index: 0;
    // avatar preview in the modal (staged or existing; pre-baked thumbnail)
    in-out property <image> cv-avatar;
    in-out property <string> cv-avatar-mode: "circle";
    in-out property <bool> cv-has-avatar: false;
    // --- avatar crop dialog (shape choice, then zoom + pan) ---
    in-out property <bool> crop-open: false;
    in-out property <string> crop-stage: "mode";  // mode | crop
    in-out property <string> crop-mode: "circle"; // circle | panel
    in-out property <image> crop-src;             // downscaled preview of the photo
    in-out property <int> crop-full-w: 0;         // original photo dimensions
    in-out property <int> crop-full-h: 0;
    in-out property <string> crop-path: "";
    in-out property <float> crop-zoom: 1.0;   // 1..4
    in-out property <float> crop-cx: 0.5;     // crop centre in source UV
    in-out property <float> crop-cy: 0.5;

    callback generate();
    callback stop();
    callback select-voice(string);
    callback compose();
    callback rewrite();
    callback download-model(string);
    callback delete-model(string);
    callback activate-model(string);
    callback play-hist(string);
    callback star-hist(string, bool);
    callback delete-hist(string);
    callback regen-hist(string);
    callback export-audio(string);
    callback export-package(string);
    callback pause();
    callback resume();
    callback seek(string, float);
    callback cv-start-record();
    callback cv-stop-record();
    callback cv-pick-file();
    callback cv-transcribe();
    callback cv-create();
    callback cv-cancel();
    callback pick-language(int);
    callback pick-engine(int);
    callback pick-effect(int);
    callback cv-pick-avatar();
    callback crop-done(bool);   // accepted?
    callback tr-toggle-record(string);  // "mic" | "system"
    callback tr-pick-file();
    callback vc-open();                 // refresh the target-voice + clip lists
    callback models-open();             // re-inspect the catalog (workers download weights lazily)
    // trim modal (✂ on recordings and history clips)
    in-out property <bool> trim-open;
    in property <string> trim-title;
    in property <[float]> trim-bars;
    in property <float> trim-duration;        // seconds
    in-out property <float> trim-start: 0.0;  // 0..1 of the clip
    in-out property <float> trim-end: 1.0;
    in property <bool> trim-playing;
    in property <bool> tr-has-source;         // a transcription recording/import exists
    callback trim-show(string);               // context: "vc" | "cv" | "tr"
    callback trim-show-hist(string);          // history clip id
    callback trim-preview(float, float);      // audition [start, end]
    callback trim-preview-stop();
    callback trim-apply(float, float);
    callback vc-toggle-record(string);  // "mic" | "system"
    callback vc-pick-file();
    callback vc-convert(int);           // index into vc-voice-names
    callback vc-save-clip();            // persist the armed source (name from vc-clip-name)
    callback vc-delete-clip(string);    // clip id
    callback vc-arm-clip(string);       // clip id -> becomes the conversion source
    callback vc-audition(string);       // clip id or "scratch" — toggles play/stop
    callback tr-refine();
    callback tr-save-capture();         // save new or update the loaded one
    callback tr-delete-capture(string); // capture id
    callback apply-fx(string, int);  // history id, effect dropdown index
    callback toggle-loop(bool);
    callback set-volume(float);
    callback export-voice(string, string);  // id, name
    callback edit-voice(string);
    callback delete-voice(string);

    // --- voices tab: profile table + inspector ---
    in property <[ProfileRow]> vp-rows;
    in-out property <string> vp-selected: "";  // inspected profile id
    in-out property <string> vp-search;
    in property <string> vi-desc;
    in property <string> vi-personality;
    in property <string> vi-lang;
    in property <string> vi-engine;
    in property <string> vi-name;
    in property <string> vi-gens;
    in property <image> vi-avatar;
    in property <bool> vi-has-avatar;
    in property <[SampleRow]> vi-samples;
    in property <string> vs-playing: "";  // sample id currently auditioning
    // --- library (▤ tab): every generation, saved and searchable ---
    in property <[LibItem]> lib-rows;
    in-out property <string> lib-search;
    in property <[string]> lib-voice-names: ["All voices"];
    in-out property <int> lib-voice-index: 0;
    in-out property <int> lib-type-index: 0;   // All / TTS / speech VC / music
    // model filter — options depend on the type chosen (set from Rust)
    in property <[string]> lib-model-names: ["All models"];
    in-out property <int> lib-model-index: 0;
    in-out property <bool> lib-starred-only: false;
    in property <string> lib-count-line;
    in-out property <string> lib-tag-id: "";   // row whose tags are being edited
    in-out property <string> lib-tag-title;
    in-out property <string> lib-tag-value;    // comma-separated editor value
    callback lib-open();                       // (re)load when the tab opens
    callback lib-refilter();                   // any filter control changed
    callback lib-save-tags();

    // --- settings (⚙ tab) ---
    in property <[string]> st-mic-names: ["System default"];
    in-out property <int> st-mic-index: 0;
    in property <[string]> st-mon-names: ["Default sink monitor"];
    in-out property <int> st-mon-index: 0;
    in property <bool> st-refine: false;
    in property <string> st-export-dir: "";
    in property <string> st-data-dir: "";
    in property <[string]> st-cap-names: ["3:00"];
    in-out property <int> st-cap-index: 0;
    in property <[string]> st-steps-names: ["25"];
    in-out property <int> st-steps-index: 0;
    callback settings-open();        // (re)load devices + engine settings
    callback st-pick-mic(int);
    callback st-pick-monitor(int);
    callback st-toggle-refine();
    callback st-pick-export-dir();
    callback st-pick-cap(int);
    callback st-pick-steps(int);
    callback theme-changed(string);  // persist the picked theme

    callback voices-open();          // (re)load the table when the tab opens
    callback voices-search(string);
    callback vp-select(string);      // row click -> inspector
    callback vs-play(string);        // audition a reference sample
    callback import-voice();

    property <string> tab: "tts";

    // --- Aero background image (behind everything; only for the vista skin) ---
    if Theme.name == "vista" : Image {
        source: @image-url("assets/backgrounds/Aero.png");
        image-fit: cover;
        x: 0; y: 0;
        width: root.width;
        height: root.height;
    }

    VerticalLayout {
        width: 100%;
        height: 100%;
        // --- title bar ---
        Rectangle {
            height: 38px; background: Theme.tb-bg;
            HorizontalLayout {
                padding-left: 12px; padding-right: 12px; spacing: 10px;
                Rectangle {
                    width: 16px; height: 16px; border-radius: 4px; y: parent.height / 2 - 8px;
                    background: @linear-gradient(135deg, Theme.acc, Theme.wave-dim);
                }
                Text { text: "Syrinx"; font-size: 13px; font-weight: 600; color: Theme.tb-fg; vertical-alignment: center; }
                Text { text: "— local AI voice studio"; font-size: 11.5px; color: Theme.tb-fg; opacity: 0.65; vertical-alignment: center; }
                Rectangle {}
                Text { text: "hyprland · workspace 3"; font-size: 10.5px; font-family: Theme.mono; color: Theme.tb-fg; opacity: 0.55; vertical-alignment: center; }
            }
        }

        HorizontalLayout {
            // --- icon rail ---
            Rectangle {
                width: 62px; background: Theme.side-bg;
                border-width: 1px; border-color: Theme.brd;
                VerticalLayout {
                    padding-top: 12px; padding-bottom: 12px; spacing: 4px; alignment: start;
                    HorizontalLayout { alignment: center; NavIcon { glyph: "▷"; active: tab == "tts"; clicked => { tab = "tts"; }
                        hover-changed(on, y) => { nav-tip = on ? "Text to Speech" : ""; nav-tip-y = y; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "◍"; active: tab == "voices"; clicked => { tab = "voices"; root.voices-open(); }
                        hover-changed(on, y) => { nav-tip = on ? "Voices" : ""; nav-tip-y = y; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "☰"; active: tab == "stt"; clicked => { tab = "stt"; }
                        hover-changed(on, y) => { nav-tip = on ? "Transcription" : ""; nav-tip-y = y; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "⇄"; active: tab == "vc"; clicked => { tab = "vc"; root.vc-open(); }
                        hover-changed(on, y) => { nav-tip = on ? "Voice Converter" : ""; nav-tip-y = y; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "▤"; active: tab == "lib"; clicked => { tab = "lib"; root.lib-open(); }
                        hover-changed(on, y) => { nav-tip = on ? "Library" : ""; nav-tip-y = y; } } }
                    HorizontalLayout { alignment: center; NavIcon { glyph: "◈"; active: tab == "models"; clicked => { tab = "models"; root.models-open(); }
                        hover-changed(on, y) => { nav-tip = on ? "Models" : ""; nav-tip-y = y; } } }
                    Rectangle {}
                    HorizontalLayout { alignment: center; NavIcon { glyph: "⚙"; active: tab == "settings"; clicked => { tab = "settings"; root.settings-open(); }
                        hover-changed(on, y) => { nav-tip = on ? "Settings" : ""; nav-tip-y = y; } } }
                }
            }

            // --- main panel ---
            Rectangle {
                background: Theme.pan-bg;
                VerticalLayout {
                    // header + theme switcher
                    HorizontalLayout {
                        padding: 16px; spacing: 14px;
                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: tab == "tts" ? "Text to Speech"
                                    : tab == "stt" ? "Transcription"
                                    : tab == "voices" ? "Voices"
                                    : tab == "vc" ? "Voice Converter"
                                    : tab == "lib" ? "Audio Library"
                                    : tab == "settings" ? "Settings"
                                    : (tab == "models" ? "Models" : "Coming soon");
                                font-size: 19px; font-weight: 700; color: Theme.name == "win95" ? #ffffff : Theme.fg;
                            }
                            Text {
                                text: tab == "tts" ? "Type it, pick a voice, hear it — all local."
                                    : tab == "stt" ? "Record or import audio — whisper turns it into text."
                                    : tab == "voices" ? "Every profile in one place — inspect, audition, manage."
                                    : tab == "vc" ? "Dub any recording with one of your voices — the delivery stays, the timbre changes."
                                    : tab == "lib" ? "Every generation, saved and searchable."
                                    : tab == "settings" ? "Audio devices, paths, keybinds and themes."
                                    : (tab == "models" ? hardware-line : "This screen is stubbed for now.");
                                font-size: 12px; color: Theme.name == "win95" ? #cfe6e6 : Theme.dim;
                            }
                        }
                        Rectangle {}
                        // theme switcher (sets the Theme global directly)
                        Rectangle {
                            border-width: 1px; border-color: Theme.brd; border-radius: Theme.rad; background: Theme.card-bg;
                            HorizontalLayout {
                                padding: 4px; spacing: 4px;
                                for th[i] in [
                                    { k: "vista", l: "Aero" }, { k: "win95", l: "'95" },
                                    { k: "ps5", l: "Astro" }, { k: "rice", l: "Rice" }, { k: "tui", l: "TTY" }
                                ] : Rectangle {
                                    border-radius: Theme.rad;
                                    background: Theme.name == th.k ? Theme.acc : transparent;
                                    tta := TouchArea { clicked => { Theme.name = th.k; root.theme-changed(th.k); } }
                                    HorizontalLayout {
                                        padding-left: 10px; padding-right: 10px;
                                        Text {
                                            text: th.l; font-size: 11.5px; vertical-alignment: center;
                                            color: Theme.name == th.k ? Theme.acc-fg : Theme.dim;
                                        }
                                    }
                                    height: 26px;
                                }
                            }
                        }
                    }

                    // ---- TTS workspace ----
                    if tab == "tts" : HorizontalLayout {
                        padding-left: 22px; padding-right: 22px; spacing: 18px;

                        // voices column
                        VerticalLayout {
                            horizontal-stretch: 5; spacing: 10px;
                            HorizontalLayout {
                                spacing: 10px;
                                Text { text: "VOICES"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" ? #ffffff : Theme.dim; vertical-alignment: center; }
                                Rectangle {}
                                TBtn { label: "Import voice"; clicked => { root.import-voice(); } }
                                TBtn { label: "✦ Create voice"; generate: true; clicked => {
                                    // clear any stale edit-mode state before a fresh create
                                    cv-edit-id = ""; cv-model-index = 0;
                                    cv-lang-index = 0; cv-language = "en";
                                    cv-has-avatar = false;
                                    cv-error = "";
                                    cv-open = true;
                                } }
                            }
                            ScrollView {
                                // 3-column card grid (model padded to a multiple of 3 in Rust,
                                // so exactly 3 equal columns always render)
                                GridLayout {
                                    spacing: 16px;
                                    for v[i] in voices : Rectangle {
                                        row: floor(i / 3);
                                        col: i - floor(i / 3) * 3;
                                        height: 162px;
                                        if v.kind == "model-defaults" : KokoroCard {
                                            width: 100%; height: 100%;
                                            selected: root.selected-voice;
                                            active: root.kokoro-active;
                                            names: root.kokoro-names;
                                            ids: root.kokoro-ids;
                                            current-index <=> root.kokoro-index;
                                            pick(id) => {
                                                root.selected-voice = id;
                                                root.kokoro-active = true;
                                                root.select-voice(id);
                                            }
                                        }
                                        if v.kind != "model-defaults" && v.kind != "empty" : VoiceCard {
                                            width: 100%; height: 100%;
                                            v: v;
                                            selected: root.selected-voice;
                                            clicked => {
                                                root.selected-voice = v.id;
                                                root.kokoro-active = false;
                                                root.select-voice(v.id);
                                            }
                                            export-clicked => { root.export-voice(v.id, v.name); }
                                            edit-clicked => { root.edit-voice(v.id); }
                                            delete-clicked => { root.del-id = v.id; root.del-name = v.name; }
                                        }
                                    }
                                }
                            }

                            // ---- composer (Voicebox-style: corner icon cluster + dropdown row) ----
                            Rectangle {
                                height: 136px;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
                                background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                VerticalLayout {
                                    padding: 10px; spacing: 8px;
                                    // text area with the icon cluster pinned to the top-right corner
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            property <length> ctx-x;
                                            property <length> ctx-y;
                                            // under the input: right-clicks only (left = caret/selection)
                                            crta := TouchArea {
                                                pointer-event(e) => {
                                                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                                        ctx-x = crta.mouse-x;
                                                        ctx-y = crta.mouse-y;
                                                        cmenu.show();
                                                    }
                                                }
                                            }
                                            if root.text == "" : Text {
                                                x: 2px; y: 2px; width: parent.width - 4px;
                                                text: selected-voice-name == "" ? "Select a voice above…"
                                                    : "Generate speech using " + selected-voice-name + "…";
                                                font-size: 13.5px; color: Theme.dim; opacity: 0.6;
                                                wrap: word-wrap; font-family: Theme.font;
                                            }
                                            // scrolls when the text outgrows the box: the viewport
                                            // must be sized explicitly or ScrollView never scrolls
                                            csv := ScrollView {
                                                x: 2px; y: 2px; width: parent.width - 4px; height: parent.height - 4px;
                                                viewport-width: self.visible-width;
                                                viewport-height: max(self.visible-height, ti.preferred-height);
                                                ti := TextInput {
                                                    page-height: csv.visible-height;
                                                    text <=> root.text;
                                                    font-size: 13.5px; color: Theme.fg; wrap: word-wrap;
                                                    single-line: false;
                                                    // keep the caret in view while typing
                                                    cursor-position-changed(cpos) => {
                                                        if (cpos.y + csv.viewport-y < 0px) {
                                                            csv.viewport-y = min(0px, max(csv.visible-height - self.height, -cpos.y));
                                                        } else if (cpos.y + csv.viewport-y > csv.visible-height - 20px) {
                                                            csv.viewport-y = min(0px, max(csv.visible-height - self.height, csv.visible-height - cpos.y - 20px));
                                                        }
                                                    }
                                                }
                                            }
                                            cmenu := PopupWindow {
                                                x: parent.ctx-x; y: parent.ctx-y;
                                                width: 150px; height: 120px;
                                                close-policy: close-on-click-outside;
                                                Rectangle {
                                                    background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                                    border-width: Theme.name == "win95" ? 0px : 1px;
                                                    border-color: Theme.brd; border-radius: Theme.rad;
                                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                                    VerticalLayout {
                                                        padding: 3px;
                                                        RowMenuItem { label: "Cut"; chosen => { ti.cut(); cmenu.close(); } }
                                                        RowMenuItem { label: "Copy"; chosen => { ti.copy(); cmenu.close(); } }
                                                        RowMenuItem { label: "Paste"; chosen => { ti.paste(); cmenu.close(); } }
                                                        RowMenuItem { label: "Select all"; chosen => { ti.select-all(); cmenu.close(); } }
                                                    }
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: start;
                                            HorizontalLayout {
                                                spacing: 6px;
                                                // ⚄ compose · ✧ speak in character · ✦ generate
                                                if selected-has-personality : IconBtn {
                                                    glyph: llm-busy ? "…" : "⚄";
                                                    tip: llm-busy ? "Thinking…" : "Compose a line in character";
                                                    enabled: !llm-busy;
                                                    clicked => { root.compose(); }
                                                }
                                                if selected-has-personality : IconBtn {
                                                    glyph: "✧"; active: persona-on;
                                                    tip: persona-on ? "Speaking in character" : "Speak in character";
                                                    clicked => { persona-on = !persona-on; }
                                                }
                                                IconBtn {
                                                    glyph: generating ? "■" : "✦"; accent: true;
                                                    tip: generating ? "Stop" : "Generate speech";
                                                    clicked => { if (generating) { root.stop(); } else { root.generate(); } }
                                                }
                                            }
                                        }
                                    }
                                    // indeterminate "working" bar — looping marquee via animation-tick()
                                    if synthesizing || llm-busy : Rectangle {
                                        height: 4px; border-radius: 2px; background: Theme.chip-bg; clip: true;
                                        Rectangle {
                                            height: 100%; width: parent.width * 0.35;
                                            border-radius: 2px; background: Theme.gen-bg;
                                            x: -self.width + (parent.width + self.width) * (mod(animation-tick(), 1200ms) / 1200ms);
                                        }
                                    }
                                    // last generation failure (cleared on the next Generate).
                                    // preferred-width 0: a long error must elide, not inflate
                                    // the composer column and squeeze the history panel.
                                    if gen-error != "" : HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "⚠ " + gen-error;
                                            font-size: 10px; font-family: Theme.mono; color: #cc3b3b;
                                            overflow: elide; preferred-width: 0px;
                                            horizontal-stretch: 1; vertical-alignment: center;
                                        }
                                        Rectangle {
                                            width: 18px; height: 16px; border-radius: Theme.rad;
                                            background: gecta.has-hover ? Theme.acc-soft : transparent;
                                            // hidden mirror input: TextInput is slint's only
                                            // clipboard access, so copy = select-all on this
                                            gecti := TextInput { text: gen-error; read-only: true; opacity: 0; width: 1px; height: 1px; }
                                            gecta := TouchArea { clicked => { gecti.select-all(); gecti.copy(); } }
                                            Text { text: "⧉"; font-size: 10px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                    }
                                    // language / engine / effects (Voicebox dropdown row; opens upward)
                                    HorizontalLayout {
                                        spacing: 8px;
                                        ThemedDropdown {
                                            up: true; horizontal-stretch: 1;
                                            model: composer-langs;
                                            current-index <=> composer-lang-index;
                                            selected(i) => { root.pick-language(i); }
                                        }
                                        ThemedDropdown {
                                            up: true; horizontal-stretch: 1;
                                            model: composer-engines;
                                            current-index <=> composer-engine-index;
                                            selected(i) => { root.pick-engine(i); }
                                        }
                                        // delivery direction — labels must match STYLES in main.rs;
                                        // hidden when the voice's engine ignores instructs
                                        if style-supported : ThemedDropdown {
                                            up: true; horizontal-stretch: 1;
                                            model: ["No direction", "Angry", "Sad", "Happy", "Excited", "Fearful", "Whisper", "Serious"];
                                            current-index <=> composer-style-index;
                                            selected(i) => { root.pick-style(i); }
                                        }
                                        ThemedDropdown {
                                            up: true; horizontal-stretch: 1;
                                            model: composer-effects;
                                            current-index <=> composer-effect-index;
                                            selected(i) => { root.pick-effect(i); }
                                        }
                                        IconBtn {
                                            glyph: "✎"; tip: "Edit effect presets";
                                            clicked => { root.fxe-show(); }
                                        }
                                    }
                                }
                            }

                            // ---- player: spawns under the text box after a generation
                            // (shared PlayerBar — the Library renders the same one) ----
                            if player-active && player-active-visible : PlayerBar {
                                p-id: player-id; p-title: player-title; p-time: player-time;
                                p-bars: player-bars; p-playing: player-playing;
                                p-paused <=> player-paused; p-loop <=> player-loop;
                                p-volume <=> player-volume; p-pct <=> play-pct;
                                play => { root.play-hist(player-id); }
                                pause => { root.pause(); }
                                resume => { root.resume(); }
                                seek(p) => { root.seek(player-id, p); }
                                toggle-loop(on) => { root.toggle-loop(on); }
                                set-volume(v) => { root.set-volume(v); }
                                trim => { root.trim-show-hist(player-id); }
                                close => { player-active-visible = false; }
                            }
                        }

                        // history column
                        Rectangle {
                            horizontal-stretch: 4;
                            // left divider (the mockup uses a single left border, not a box)
                            Rectangle { x: 0; y: 0; width: 1px; height: 100%; background: Theme.brd; }
                            VerticalLayout {
                                padding-left: 18px; spacing: 10px;
                                Text { text: "HISTORY"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" ? #ffffff : Theme.dim; }
                                ScrollView {
                                    VerticalLayout {
                                        spacing: 8px;
                                        for h[i] in history : Rectangle {
                                            // fixed height so the ScrollView scrolls instead of
                                            // squeezing cards into each other as history grows
                                            height: 106px;
                                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad; background: Theme.card-bg;
                                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                            VerticalLayout {
                                                padding: 11px; spacing: 8px;
                                                HorizontalLayout {
                                                    spacing: 8px;
                                                    // round play button
                                                    Rectangle {
                                                        width: 28px; height: 28px;
                                                        border-radius: Theme.name == "win95" ? 0px : 14px;
                                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                                        border-color: Theme.btn-brd;
                                                        background: (pb.pressed && Theme.name != "win95") ? Theme.acc-soft : Theme.btn-bg;
                                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: pb.pressed; }
                                                        pb := TouchArea { clicked => { root.play-hist(h.id); } }
                                                        Text { text: "▶"; font-size: 10px; color: Theme.btn-fg;
                                                               horizontal-alignment: center; vertical-alignment: center; }
                                                    }
                                                    // voice + meta
                                                    VerticalLayout {
                                                        alignment: center; spacing: 1px; horizontal-stretch: 1;
                                                        Text { text: h.voice; font-size: 12.5px; font-weight: 700; color: Theme.fg; overflow: elide; }
                                                        Text { text: h.meta; font-size: 10px; font-family: Theme.mono; color: Theme.dim; overflow: elide; }
                                                    }
                                                    // mini waveform (decorative until level data is wired)
                                                    Rectangle {
                                                        height: 22px;
                                                        HorizontalLayout {
                                                            spacing: 2px; alignment: end;
                                                            for bh in [7, 12, 8, 16, 10, 18, 9, 14, 11, 15] : VerticalLayout {
                                                                alignment: end;
                                                                Rectangle { width: 3px; height: bh * 1px; border-radius: 1px; background: Theme.wave-dim; }
                                                            }
                                                        }
                                                    }
                                                    // star toggle (always visible, Voicebox-style)
                                                    Rectangle {
                                                        width: 22px; height: 22px; border-radius: Theme.rad;
                                                        background: sta.has-hover ? Theme.acc-soft : transparent;
                                                        sta := TouchArea { clicked => { root.star-hist(h.id, !h.starred); } }
                                                        Text { text: h.starred ? "★" : "☆"; font-size: 14px;
                                                               color: h.starred ? Theme.acc : Theme.dim;
                                                               horizontal-alignment: center; vertical-alignment: center; }
                                                    }
                                                    // 3-dot menu
                                                    RowMenu {
                                                        play => { root.play-hist(h.id); }
                                                        regen => { root.regen-hist(h.id); }
                                                        export-audio => { root.export-audio(h.id); }
                                                        export-package => { root.export-package(h.id); }
                                                        apply-effects => { root.fx-id = h.id; root.fx-voice = h.voice; root.fx-index = 0; }
                                                        del => { root.delete-hist(h.id); }
                                                    }
                                                }
                                                // message text — read-only, scrollable, selectable
                                                // (Ctrl+C or right-click → themed menu)
                                                Rectangle {
                                                    height: 48px;
                                                    property <length> ctx-x;
                                                    property <length> ctx-y;
                                                    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                                    border-radius: Theme.rad;
                                                    background: Theme.name == "win95" ? #ffffff : Theme.pan-bg;
                                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                                    // under the input: catches the right-clicks the
                                                    // TextInput ignores; left-click selection still works
                                                    rcta := TouchArea {
                                                        pointer-event(e) => {
                                                            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                                                ctx-x = rcta.mouse-x;
                                                                ctx-y = rcta.mouse-y;
                                                                ctxpop.show();
                                                            }
                                                        }
                                                    }
                                                    hsv := ScrollView {
                                                        x: 7px; y: 4px;
                                                        width: parent.width - 14px; height: parent.height - 8px;
                                                        viewport-width: self.visible-width;
                                                        viewport-height: max(self.visible-height, hti.preferred-height);
                                                        hti := TextInput {
                                                            page-height: hsv.visible-height;
                                                            text: h.text;
                                                            read-only: true;
                                                            wrap: word-wrap; single-line: false;
                                                            font-size: 11.5px; color: Theme.dim; font-family: Theme.font;
                                                            // drag-select past the edge scrolls to follow
                                                            cursor-position-changed(cpos) => {
                                                                if (cpos.y + hsv.viewport-y < 0px) {
                                                                    hsv.viewport-y = min(0px, max(hsv.visible-height - self.height, -cpos.y));
                                                                } else if (cpos.y + hsv.viewport-y > hsv.visible-height - 20px) {
                                                                    hsv.viewport-y = min(0px, max(hsv.visible-height - self.height, hsv.visible-height - cpos.y - 20px));
                                                                }
                                                            }
                                                        }
                                                    }
                                                    ctxpop := PopupWindow {
                                                        x: parent.ctx-x; y: parent.ctx-y;
                                                        width: 150px; height: 92px;
                                                        close-policy: close-on-click-outside;
                                                        Rectangle {
                                                            background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                                            border-width: Theme.name == "win95" ? 0px : 1px;
                                                            border-color: Theme.brd; border-radius: Theme.rad;
                                                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                                            VerticalLayout {
                                                                padding: 3px;
                                                                RowMenuItem { label: "Copy"; chosen => { hti.copy(); ctxpop.close(); } }
                                                                RowMenuItem { label: "Copy all"; chosen => { hti.select-all(); hti.copy(); ctxpop.close(); } }
                                                                RowMenuItem { label: "Select all"; chosen => { hti.select-all(); ctxpop.close(); } }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                        if history.length == 0 : Text {
                                            text: "— nothing generated yet —"; font-size: 10.5px; font-family: Theme.mono;
                                            color: Theme.dim; horizontal-alignment: center;
                                        }
                                        if history.length > 0 : Text {
                                            text: "— end of history —"; font-size: 10.5px; font-family: Theme.mono;
                                            color: Theme.dim; horizontal-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ---- Transcription workspace ----
                    if tab == "stt" : HorizontalLayout {
                        padding-left: 22px; padding-right: 22px; padding-bottom: 16px; spacing: 14px;
                        // captures rail — persisted transcripts (text only); click to load
                        VerticalLayout {
                            width: 210px; spacing: 10px;
                            Text { text: "CAPTURES"; font-size: 12px; font-weight: 700; color: Theme.dim; }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    spacing: 8px;
                                    for c in captures : Rectangle {
                                        // fixed height so the ScrollView scrolls (it squeezes
                                        // flexible children instead)
                                        height: 96px;
                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                        border-color: c.id == tr-capture-id ? Theme.acc : Theme.brd;
                                        border-radius: Theme.rad;
                                        background: c.id == tr-capture-id ? Theme.acc-soft : Theme.card-bg;
                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                        capta := TouchArea {
                                            clicked => {
                                                if (!tr-busy && !tr-recording) {
                                                    tr-capture-id = c.id;
                                                    tr-text = c.text;
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            padding: 10px; spacing: 6px;
                                            HorizontalLayout {
                                                spacing: 6px;
                                                Text {
                                                    text: c.date; font-size: 9.5px; font-family: Theme.mono;
                                                    color: Theme.dim; vertical-alignment: center; horizontal-stretch: 1;
                                                }
                                                Rectangle {
                                                    width: 18px; height: 18px; border-radius: Theme.rad;
                                                    background: cload.has-hover ? Theme.acc-soft : transparent;
                                                    cload := TouchArea {
                                                        clicked => {
                                                            if (!tr-busy && !tr-recording) {
                                                                tr-capture-id = c.id;
                                                                tr-text = c.text;
                                                            }
                                                        }
                                                    }
                                                    Text { text: "✎"; font-size: 11px; color: Theme.dim;
                                                           horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                                Rectangle {
                                                    width: 18px; height: 18px; border-radius: Theme.rad;
                                                    background: cdel.has-hover ? Theme.acc-soft : transparent;
                                                    cdel := TouchArea { clicked => { root.tr-delete-capture(c.id); } }
                                                    Text { text: "✕"; font-size: 11px; color: Theme.dim;
                                                           horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                            }
                                            // text — read-only, scrollable, selectable (same
                                            // principle as the history-card message box)
                                            Rectangle {
                                                height: 52px;
                                                property <length> ctx-x;
                                                property <length> ctx-y;
                                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                                border-radius: Theme.rad;
                                                background: Theme.name == "win95" ? #ffffff : Theme.pan-bg;
                                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                                ccta := TouchArea {
                                                    pointer-event(e) => {
                                                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                                            ctx-x = ccta.mouse-x;
                                                            ctx-y = ccta.mouse-y;
                                                            cctx.show();
                                                        }
                                                    }
                                                }
                                                capsv := ScrollView {
                                                    x: 7px; y: 4px;
                                                    width: parent.width - 14px; height: parent.height - 8px;
                                                    viewport-width: self.visible-width;
                                                    viewport-height: max(self.visible-height, capti.preferred-height);
                                                    capti := TextInput {
                                                        page-height: capsv.visible-height;
                                                        text: c.text;
                                                        read-only: true;
                                                        wrap: word-wrap; single-line: false;
                                                        font-size: 10.5px; color: Theme.dim; font-family: Theme.font;
                                                        // drag-select past the edge scrolls to follow
                                                        cursor-position-changed(cpos) => {
                                                            if (cpos.y + capsv.viewport-y < 0px) {
                                                                capsv.viewport-y = min(0px, max(capsv.visible-height - self.height, -cpos.y));
                                                            } else if (cpos.y + capsv.viewport-y > capsv.visible-height - 20px) {
                                                                capsv.viewport-y = min(0px, max(capsv.visible-height - self.height, capsv.visible-height - cpos.y - 20px));
                                                            }
                                                        }
                                                    }
                                                }
                                                cctx := PopupWindow {
                                                    x: parent.ctx-x; y: parent.ctx-y;
                                                    width: 150px; height: 92px;
                                                    close-policy: close-on-click-outside;
                                                    Rectangle {
                                                        background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                                        border-color: Theme.brd; border-radius: Theme.rad;
                                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                                        VerticalLayout {
                                                            padding: 3px;
                                                            RowMenuItem { label: "Copy"; chosen => { capti.copy(); cctx.close(); } }
                                                            RowMenuItem { label: "Copy all"; chosen => { capti.select-all(); capti.copy(); cctx.close(); } }
                                                            RowMenuItem { label: "Select all"; chosen => { capti.select-all(); cctx.close(); } }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    if captures.length == 0 : Text {
                                        text: "— no captures yet —"; font-size: 10.5px; font-family: Theme.mono;
                                        color: Theme.dim; horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                        // workspace column
                        VerticalLayout {
                            spacing: 12px; horizontal-stretch: 1;
                            // sources
                            HorizontalLayout {
                                spacing: 8px;
                                TBtn {
                                    label: tr-recording && tr-rec-mode == "mic" ? "■ Stop" : "● Record mic";
                                    generate: tr-recording && tr-rec-mode == "mic";
                                    clicked => { if (!tr-busy) { root.tr-toggle-record("mic"); } }
                                }
                                TBtn {
                                    label: tr-recording && tr-rec-mode == "system" ? "■ Stop" : "◉ Record system";
                                    generate: tr-recording && tr-rec-mode == "system";
                                    clicked => { if (!tr-busy) { root.tr-toggle-record("system"); } }
                                }
                                TBtn {
                                    label: "⇪ Import audio…";
                                    clicked => { if (!tr-busy && !tr-recording) { root.tr-pick-file(); } }
                                }
                                Rectangle {}
                                Text {
                                    text: tr-status; font-size: 11px; font-family: Theme.mono;
                                    color: Theme.dim; vertical-alignment: center;
                                }
                            }
                            // transcript — editable, scrollable, right-click menu
                            Rectangle {
                                vertical-stretch: 1;
                                property <length> ctx-x;
                                property <length> ctx-y;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad;
                                background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                trta := TouchArea {
                                    pointer-event(e) => {
                                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                            ctx-x = trta.mouse-x;
                                            ctx-y = trta.mouse-y;
                                            trmenu.show();
                                        }
                                    }
                                }
                                if tr-text == "" && !tr-busy : Text {
                                    x: 12px; y: 10px; width: parent.width - 24px;
                                    text: "Record from the microphone, tap the system audio, or import a file — the transcript lands here, live as it decodes.";
                                    font-size: 13px; color: Theme.dim; opacity: 0.6;
                                    wrap: word-wrap; font-family: Theme.font;
                                }
                                trsv := ScrollView {
                                    x: 12px; y: 10px;
                                    width: parent.width - 24px; height: parent.height - 26px;
                                    viewport-width: self.visible-width;
                                    viewport-height: max(self.visible-height, trti.preferred-height);
                                    trti := TextInput {
                                        page-height: trsv.visible-height;
                                        text <=> tr-text;
                                        wrap: word-wrap; single-line: false;
                                        font-size: 13.5px; color: Theme.fg; font-family: Theme.font;
                                        // keep the caret in view while typing
                                        cursor-position-changed(cpos) => {
                                            if (cpos.y + trsv.viewport-y < 0px) {
                                                trsv.viewport-y = min(0px, max(trsv.visible-height - self.height, -cpos.y));
                                            } else if (cpos.y + trsv.viewport-y > trsv.visible-height - 20px) {
                                                trsv.viewport-y = min(0px, max(trsv.visible-height - self.height, trsv.visible-height - cpos.y - 20px));
                                            }
                                        }
                                    }
                                }
                                trmenu := PopupWindow {
                                    x: parent.ctx-x; y: parent.ctx-y;
                                    width: 150px; height: 120px;
                                    close-policy: close-on-click-outside;
                                    Rectangle {
                                        background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                        border-color: Theme.brd; border-radius: Theme.rad;
                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                        VerticalLayout {
                                            padding: 3px;
                                            RowMenuItem { label: "Cut"; chosen => { trti.cut(); trmenu.close(); } }
                                            RowMenuItem { label: "Copy"; chosen => { trti.copy(); trmenu.close(); } }
                                            RowMenuItem { label: "Paste"; chosen => { trti.paste(); trmenu.close(); } }
                                            RowMenuItem { label: "Select all"; chosen => { trti.select-all(); trmenu.close(); } }
                                        }
                                    }
                                }
                            }
                            // indeterminate "working" bar while transcribing / refining —
                            // same looping marquee as the composer
                            if tr-busy : Rectangle {
                                height: 4px; border-radius: 2px; background: Theme.chip-bg; clip: true;
                                Rectangle {
                                    height: 100%; width: parent.width * 0.35;
                                    border-radius: 2px; background: Theme.gen-bg;
                                    x: -self.width + (parent.width + self.width) * (mod(animation-tick(), 1200ms) / 1200ms);
                                }
                            }
                            // actions
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Transcript is editable — fix names before using it.";
                                    font-size: 10.5px; font-family: Theme.mono; color: Theme.dim;
                                    vertical-alignment: center;
                                }
                                Rectangle {}
                                if tr-has-source : TBtn {
                                    label: "✂ Trim";
                                    clicked => { if (!tr-busy && !tr-recording) { root.trim-show("tr"); } }
                                }
                                TBtn {
                                    label: tr-capture-id == "" ? "▤ Save capture" : "▤ Update capture";
                                    clicked => { if (!tr-busy && tr-text != "") { root.tr-save-capture(); } }
                                }
                                TBtn {
                                    label: tr-busy ? "…" : "✎ Refine with LLM";
                                    clicked => { if (!tr-busy && tr-text != "") { root.tr-refine(); } }
                                }
                                TBtn {
                                    label: "✦ Use in composer"; generate: true; min-width: 150px;
                                    clicked => {
                                        if (tr-text != "") {
                                            root.text = tr-text;
                                            tab = "tts";
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ---- Voice Changer (style-preserved voice conversion) ----
                    if tab == "vc" : HorizontalLayout {
                        padding-left: 22px; padding-right: 22px; padding-bottom: 16px; spacing: 14px;
                        // saved source clips rail — click to arm, ▶ to audition
                        VerticalLayout {
                            width: 210px; spacing: 10px;
                            Text { text: "SOURCE CLIPS"; font-size: 12px; font-weight: 700; color: Theme.dim; }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    spacing: 8px;
                                    for c in vc-clips : Rectangle {
                                        // fixed height so the ScrollView scrolls
                                        height: 58px;
                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                        border-color: c.id == vc-armed-id ? Theme.acc : Theme.brd;
                                        border-radius: Theme.rad;
                                        background: c.id == vc-armed-id ? Theme.acc-soft : Theme.card-bg;
                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                        scta := TouchArea {
                                            clicked => {
                                                if (!vc-busy && !vc-recording) { root.vc-arm-clip(c.id); }
                                            }
                                        }
                                        VerticalLayout {
                                            padding: 10px; spacing: 4px;
                                            HorizontalLayout {
                                                spacing: 6px;
                                                Text {
                                                    text: c.name; font-size: 11.5px; font-weight: 700; color: Theme.fg;
                                                    overflow: elide; horizontal-stretch: 1; vertical-alignment: center;
                                                }
                                                Rectangle {
                                                    width: 18px; height: 18px; border-radius: Theme.rad;
                                                    background: scplay.has-hover ? Theme.acc-soft : transparent;
                                                    scplay := TouchArea { clicked => { root.vc-audition(c.id); } }
                                                    Text {
                                                        text: vc-audition-id == c.id ? "■" : "▶";
                                                        font-size: 11px; color: vc-audition-id == c.id ? Theme.acc : Theme.dim;
                                                        horizontal-alignment: center; vertical-alignment: center;
                                                    }
                                                }
                                                Rectangle {
                                                    width: 18px; height: 18px; border-radius: Theme.rad;
                                                    background: scdel.has-hover ? Theme.acc-soft : transparent;
                                                    scdel := TouchArea { clicked => { root.vc-delete-clip(c.id); } }
                                                    Text { text: "✕"; font-size: 11px; color: Theme.dim;
                                                           horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                            }
                                            Text { text: c.meta; font-size: 9.5px; font-family: Theme.mono; color: Theme.dim; }
                                        }
                                    }
                                    if vc-clips.length == 0 : Text {
                                        text: "— no saved clips yet —"; font-size: 10.5px; font-family: Theme.mono;
                                        color: Theme.dim; horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                        // workspace column
                        VerticalLayout {
                            spacing: 12px; horizontal-stretch: 1;
                            // mode toggle — speech dub vs full-song cover
                            HorizontalLayout {
                                spacing: 10px;
                                Rectangle {
                                    border-width: 1px; border-color: Theme.brd; border-radius: Theme.rad; background: Theme.card-bg;
                                    HorizontalLayout {
                                        padding: 4px; spacing: 4px;
                                        for md in [
                                            { k: "speech", l: "Speech" }, { k: "music", l: "♫ Music" }
                                        ] : Rectangle {
                                            border-radius: Theme.rad;
                                            background: vc-mode == md.k ? Theme.acc : transparent;
                                            TouchArea { clicked => { if (!vc-busy && !vc-recording) { vc-mode = md.k; } } }
                                            HorizontalLayout {
                                                padding-left: 10px; padding-right: 10px;
                                                Text {
                                                    text: md.l; font-size: 11.5px; vertical-alignment: center;
                                                    color: vc-mode == md.k ? Theme.acc-fg : Theme.dim;
                                                }
                                            }
                                            height: 26px;
                                        }
                                    }
                                }
                                Text {
                                    text: vc-mode == "music"
                                        ? "vocals are isolated, converted, and remixed over the instrumental"
                                        : "";
                                    font-size: 10.5px; font-family: Theme.mono;
                                    color: Theme.name == "vista" ? #ffffff : Theme.dim;
                                    vertical-alignment: center; overflow: elide;
                                    preferred-width: 0px; horizontal-stretch: 1;
                                }
                            }
                            // 1 — source
                            Text { text: "1 · SOURCE AUDIO"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            HorizontalLayout {
                                spacing: 8px;
                                TBtn {
                                    label: vc-recording && vc-rec-mode == "mic" ? "■ Stop" : "● Record mic";
                                    generate: vc-recording && vc-rec-mode == "mic";
                                    clicked => { if (!vc-busy) { root.vc-toggle-record("mic"); } }
                                }
                                TBtn {
                                    label: vc-recording && vc-rec-mode == "system" ? "■ Stop" : "◉ Record system";
                                    generate: vc-recording && vc-rec-mode == "system";
                                    clicked => { if (!vc-busy) { root.vc-toggle-record("system"); } }
                                }
                                TBtn {
                                    label: "⇪ Import audio…";
                                    clicked => { if (!vc-busy && !vc-recording) { root.vc-pick-file(); } }
                                }
                                Rectangle {}
                                Text {
                                    text: vc-status; font-size: 11px; font-family: Theme.mono;
                                    color: Theme.dim; vertical-alignment: center;
                                }
                            }
                            // armed source (history-card-style sunken box) + ▶ verify
                            HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    height: 46px; horizontal-stretch: 1;
                                    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                    border-radius: Theme.rad;
                                    background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                    HorizontalLayout {
                                        padding-left: 12px; padding-right: 12px;
                                        Text {
                                            text: vc-has-source ? vc-source-label
                                                : "No source yet — record or import the audio to convert.";
                                            font-size: 12px; font-family: Theme.font;
                                            color: vc-has-source ? Theme.fg : Theme.dim;
                                            opacity: vc-has-source ? 1.0 : 0.6;
                                            vertical-alignment: center; overflow: elide;
                                        }
                                    }
                                }
                                TBtn {
                                    label: vc-audition-id == (vc-armed-id == "" ? "scratch" : vc-armed-id) ? "■ Stop" : "▶ Play";
                                    clicked => {
                                        if (vc-has-source && !vc-recording) {
                                            root.vc-audition(vc-armed-id == "" ? "scratch" : vc-armed-id);
                                        }
                                    }
                                }
                                TBtn {
                                    label: "✂ Trim";
                                    clicked => {
                                        if (vc-has-source && !vc-recording && !vc-busy && !vc-transcribing) {
                                            root.trim-show("vc");
                                        }
                                    }
                                }
                            }
                            // persist the armed clip (hidden once it's already stored)
                            if vc-has-source && !vc-armed-saved : HorizontalLayout {
                                spacing: 8px;
                                LabeledInput {
                                    label: "CLIP NAME"; placeholder: "e.g. Interview excerpt";
                                    label-color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim;
                                    value <=> vc-clip-name; horizontal-stretch: 1; vertical-stretch: 0;
                                }
                                VerticalLayout {
                                    alignment: end;
                                    TBtn { label: "▤ Save clip"; clicked => { if (!vc-recording) { root.vc-save-clip(); } } }
                                }
                            }
                            // auto-transcript of the armed source — read-only,
                            // selectable, right-click copy (capture-card pattern).
                            // This box takes the column's spare height.
                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: "SOURCE TRANSCRIPT"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; vertical-alignment: center; }
                                Rectangle {}
                                if vc-transcribing : Text {
                                    text: "transcribing…"; font-size: 10.5px; font-family: Theme.mono;
                                    color: Theme.dim; vertical-alignment: center;
                                }
                            }
                            Rectangle {
                                vertical-stretch: 1; min-height: 64px;
                                property <length> ctx-x;
                                property <length> ctx-y;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad;
                                background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                vtta := TouchArea {
                                    pointer-event(e) => {
                                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                            ctx-x = vtta.mouse-x;
                                            ctx-y = vtta.mouse-y;
                                            vtmenu.show();
                                        }
                                    }
                                }
                                if vc-transcript == "" && !vc-transcribing : Text {
                                    x: 12px; y: 8px; width: parent.width - 24px;
                                    text: vc-has-source ? "No speech detected in this source."
                                        : "The source's words appear here — recorded, imported or picked from the rail.";
                                    font-size: 11.5px; color: Theme.dim; opacity: 0.6;
                                    wrap: word-wrap; font-family: Theme.font;
                                }
                                vtsv := ScrollView {
                                    x: 12px; y: 8px;
                                    width: parent.width - 24px; height: parent.height - 16px;
                                    viewport-width: self.visible-width;
                                    viewport-height: max(self.visible-height, vtti.preferred-height);
                                    vtti := TextInput {
                                        page-height: vtsv.visible-height;
                                        text: vc-transcript;
                                        read-only: true;
                                        wrap: word-wrap; single-line: false;
                                        font-size: 12px; color: Theme.fg; font-family: Theme.font;
                                        // drag-select past the edge scrolls to follow
                                        cursor-position-changed(cpos) => {
                                            if (cpos.y + vtsv.viewport-y < 0px) {
                                                vtsv.viewport-y = min(0px, max(vtsv.visible-height - self.height, -cpos.y));
                                            } else if (cpos.y + vtsv.viewport-y > vtsv.visible-height - 20px) {
                                                vtsv.viewport-y = min(0px, max(vtsv.visible-height - self.height, vtsv.visible-height - cpos.y - 20px));
                                            }
                                        }
                                    }
                                }
                                vtmenu := PopupWindow {
                                    x: parent.ctx-x; y: parent.ctx-y;
                                    width: 150px; height: 92px;
                                    close-policy: close-on-click-outside;
                                    Rectangle {
                                        background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                        border-color: Theme.brd; border-radius: Theme.rad;
                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                        VerticalLayout {
                                            padding: 3px;
                                            RowMenuItem { label: "Copy"; chosen => { vtti.copy(); vtmenu.close(); } }
                                            RowMenuItem { label: "Copy all"; chosen => { vtti.select-all(); vtti.copy(); vtmenu.close(); } }
                                            RowMenuItem { label: "Select all"; chosen => { vtti.select-all(); vtmenu.close(); } }
                                        }
                                    }
                                }
                            }
                            // 2 — target voice + result name + convert
                            Text { text: "2 · TARGET VOICE"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            LabeledInput {
                                label: "RESULT NAME (optional)"; placeholder: "Type conversion name here…";
                                label-color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim;
                                value <=> vc-result-name; vertical-stretch: 0;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                ThemedDropdown {
                                    horizontal-stretch: 2;
                                    model: vc-voice-names;
                                    current-index <=> vc-voice-index;
                                }
                                // which model performs the conversion (music
                                // mode lists only singing-capable engines)
                                if vc-mode == "speech" : ThemedDropdown {
                                    horizontal-stretch: 1;
                                    model: vc-engine-names;
                                    current-index <=> vc-engine-index;
                                }
                                if vc-mode == "music" : ThemedDropdown {
                                    horizontal-stretch: 1;
                                    model: vc-music-engine-names;
                                    current-index <=> vc-music-engine-index;
                                }
                                // octave shifter — moves the sung register in
                                // key-preserving ±12-semitone steps (deep
                                // voices sing high songs an octave down)
                                if vc-mode == "music" : ThemedDropdown {
                                    width: 88px;
                                    model: ["−2 oct", "−1 oct", "±0 oct", "+1 oct", "+2 oct"];
                                    current-index <=> vc-octave-index;
                                }
                                TBtn {
                                    label: vc-busy ? "…" : (vc-mode == "music" ? "♫ Convert" : "⇄ Convert");
                                    generate: true; min-width: 130px;
                                    clicked => {
                                        if (!vc-busy && !vc-recording && vc-has-source && vc-voice-names.length > 0) {
                                            root.vc-convert(vc-voice-index);
                                        }
                                    }
                                }
                            }
                            // indeterminate "working" bar — same looping marquee as the composer
                            if vc-busy : Rectangle {
                                height: 4px; border-radius: 2px; background: Theme.chip-bg; clip: true;
                                Rectangle {
                                    height: 100%; width: parent.width * 0.35;
                                    border-radius: 2px; background: Theme.gen-bg;
                                    x: -self.width + (parent.width + self.width) * (mod(animation-tick(), 1200ms) / 1200ms);
                                }
                            }
                            if vc-voice-names.length == 0 : Text {
                                text: "No cloned voices yet — create one first (✦ Create voice in Text to Speech).";
                                font-size: 11px; font-family: Theme.mono;
                                color: Theme.name == "vista" ? #ffffff : Theme.dim;
                            }
                            // last conversion failure (composer error-line pattern:
                            // elide + ⧉ copy; preferred-width 0 so it can't inflate)
                            if vc-error != "" : HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: "⚠ " + vc-error;
                                    font-size: 10px; font-family: Theme.mono; color: #cc3b3b;
                                    overflow: elide; preferred-width: 0px;
                                    horizontal-stretch: 1; vertical-alignment: center;
                                }
                                Rectangle {
                                    width: 18px; height: 16px; border-radius: Theme.rad;
                                    background: vecta.has-hover ? Theme.acc-soft : transparent;
                                    vecti := TextInput { text: vc-error; read-only: true; opacity: 0; width: 1px; height: 1px; }
                                    vecta := TouchArea { clicked => { vecti.select-all(); vecti.copy(); } }
                                    Text { text: "⧉"; font-size: 10px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                            // the same bottom player the TTS and Library views show —
                            // appears live the moment a finished conversion auto-plays
                            if player-active && player-active-visible : PlayerBar {
                                p-id: player-id; p-title: player-title; p-time: player-time;
                                p-bars: player-bars; p-playing: player-playing;
                                p-paused <=> player-paused; p-loop <=> player-loop;
                                p-volume <=> player-volume; p-pct <=> play-pct;
                                play => { root.play-hist(player-id); }
                                pause => { root.pause(); }
                                resume => { root.resume(); }
                                seek(p) => { root.seek(player-id, p); }
                                toggle-loop(on) => { root.toggle-loop(on); }
                                set-volume(v) => { root.set-volume(v); }
                                trim => { root.trim-show-hist(player-id); }
                                close => { player-active-visible = false; }
                            }
                            Text {
                                text: vc-mode == "music"
                                    ? "Music mode: the vocal track is isolated (demucs), converted to the target voice with melody-following f0, and remixed over the original instrumental. Results land in the rail and History with a ♫ mark."
                                    : "The conversion keeps the original words, timing and delivery — only the voice changes. Results play when ready and land in the rail here and in History (labeled ⇄ VC).";
                                font-size: 11px; wrap: word-wrap;
                                color: Theme.name == "vista" ? #ffffff : Theme.dim;
                            }
                        }
                        // conversion results rail — the same history rows,
                        // filtered to VC engines (labeled "⇄ VC" in the TTS list)
                        VerticalLayout {
                            width: 210px; spacing: 10px;
                            Text { text: "CONVERSIONS"; font-size: 12px; font-weight: 700; color: Theme.dim; }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    spacing: 8px;
                                    // the toggle picks which conversions show
                                    for h in (vc-mode == "music" ? vc-history-music : vc-history-speech) : Rectangle {
                                        // fixed height so the ScrollView scrolls
                                        height: 84px;
                                        border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                        border-radius: Theme.rad; background: Theme.card-bg;
                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                        VerticalLayout {
                                            padding: 10px; spacing: 4px;
                                            // voice · optional title (the row's text is the transcript)
                                            Text { text: h.voice; font-size: 11.5px; font-weight: 700; color: Theme.fg; overflow: elide; }
                                            Text { text: h.meta; font-size: 9.5px; font-family: Theme.mono; color: Theme.dim; overflow: elide; }
                                            HorizontalLayout {
                                                spacing: 4px;
                                                Rectangle {
                                                    width: 22px; height: 18px; border-radius: Theme.rad;
                                                    background: vhp.has-hover ? Theme.acc-soft : transparent;
                                                    // toggles like the sample/source-clip auditions:
                                                    // ■ while this row is the playing clip, ▶ otherwise
                                                    vhp := TouchArea {
                                                        clicked => {
                                                            if (player-id == h.id && player-playing) {
                                                                root.stop();
                                                            } else {
                                                                root.play-hist(h.id);
                                                            }
                                                        }
                                                    }
                                                    Text {
                                                        text: player-id == h.id && player-playing ? "■" : "▶";
                                                        font-size: 11px;
                                                        color: player-id == h.id && player-playing ? Theme.acc : Theme.dim;
                                                        horizontal-alignment: center; vertical-alignment: center;
                                                    }
                                                }
                                                Rectangle {
                                                    width: 22px; height: 18px; border-radius: Theme.rad;
                                                    background: vhe.has-hover ? Theme.acc-soft : transparent;
                                                    vhe := TouchArea { clicked => { root.export-audio(h.id); } }
                                                    Text { text: "⇩"; font-size: 11px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                                Rectangle {
                                                    width: 22px; height: 18px; border-radius: Theme.rad;
                                                    background: vhd.has-hover ? Theme.acc-soft : transparent;
                                                    vhd := TouchArea { clicked => { root.delete-hist(h.id); } }
                                                    Text { text: "✕"; font-size: 11px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                                Rectangle {}
                                            }
                                        }
                                    }
                                    if (vc-mode == "music" ? vc-history-music.length : vc-history-speech.length) == 0 : Text {
                                        text: vc-mode == "music" ? "— no music conversions yet —" : "— no speech conversions yet —";
                                        font-size: 10.5px; font-family: Theme.mono;
                                        color: Theme.dim; horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // ---- Audio Library: every generation, saved and searchable ----
                    if tab == "lib" : VerticalLayout {
                        padding-left: 22px; padding-right: 22px; padding-bottom: 16px; spacing: 10px;
                        // toolbar: search · type · voice · starred
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle {
                                height: 32px; horizontal-stretch: 1;
                                background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                if lib-search == "" : Text {
                                    x: 9px; y: 8px; text: "Search titles, words, tags…";
                                    font-size: 12.5px; color: Theme.dim; opacity: 0.6; font-family: Theme.font;
                                }
                                TextInput {
                                    x: 9px; y: 8px; width: parent.width - 18px; height: parent.height - 14px;
                                    text <=> lib-search; font-size: 12.5px; color: Theme.fg; font-family: Theme.font;
                                    single-line: true; wrap: no-wrap;
                                    edited => { root.lib-refilter(); }
                                }
                            }
                            ThemedDropdown {
                                width: 140px;
                                model: ["All types", "TTS", "⇄ Speech VC", "♫ Music"];
                                current-index <=> lib-type-index;
                                // a new type invalidates the model choice
                                selected(i) => { lib-model-index = 0; root.lib-refilter(); }
                            }
                            ThemedDropdown {
                                width: 150px;
                                model: lib-model-names;
                                current-index <=> lib-model-index;
                                selected(i) => { root.lib-refilter(); }
                            }
                            ThemedDropdown {
                                width: 150px;
                                model: lib-voice-names;
                                current-index <=> lib-voice-index;
                                selected(i) => { root.lib-refilter(); }
                            }
                            TBtn {
                                label: lib-starred-only ? "★ Starred" : "☆ Starred";
                                generate: lib-starred-only;
                                clicked => { lib-starred-only = !lib-starred-only; root.lib-refilter(); }
                            }
                        }
                        Text {
                            text: lib-count-line; font-size: 10.5px; font-family: Theme.mono;
                            color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim;
                        }
                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 8px;
                                for r in lib-rows : Rectangle {
                                    // fixed height so the ScrollView scrolls
                                    height: 126px;
                                    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                    border-radius: Theme.rad; background: Theme.card-bg;
                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                    VerticalLayout {
                                        padding: 12px; spacing: 6px;
                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text { text: r.title; font-size: 13px; font-weight: 700; color: Theme.fg; overflow: elide; horizontal-stretch: 1; }
                                            Text { text: r.meta; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                                        }
                                        // words — read-only, selectable (capture-card pattern, no menu)
                                        Rectangle {
                                            height: 34px;
                                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                            border-radius: Theme.rad;
                                            background: Theme.name == "win95" ? #ffffff : Theme.pan-bg;
                                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                            lrsv := ScrollView {
                                                x: 8px; y: 4px; width: parent.width - 16px; height: parent.height - 8px;
                                                viewport-width: self.visible-width;
                                                viewport-height: max(self.visible-height, lrti.preferred-height);
                                                lrti := TextInput {
                                                    page-height: lrsv.visible-height;
                                                    text: r.text; read-only: true;
                                                    wrap: word-wrap; single-line: false;
                                                    font-size: 10.5px; color: Theme.dim; font-family: Theme.font;
                                                }
                                            }
                                        }
                                        HorizontalLayout {
                                            spacing: 5px;
                                            IconBtn {
                                                size: 22px; glyph-size: 10px;
                                                glyph: player-id == r.id && player-playing ? "■" : "▶";
                                                active: player-id == r.id && player-playing;
                                                tip: player-id == r.id && player-playing ? "Stop" : "Play";
                                                clicked => {
                                                    if (player-id == r.id && player-playing) { root.stop(); }
                                                    else { root.play-hist(r.id); }
                                                }
                                            }
                                            IconBtn {
                                                size: 22px; glyph-size: 10px;
                                                glyph: r.starred ? "★" : "☆"; active: r.starred;
                                                tip: r.starred ? "Unstar" : "Star";
                                                clicked => { root.star-hist(r.id, !r.starred); }
                                            }
                                            IconBtn {
                                                size: 22px; glyph-size: 10px; glyph: "⇩"; tip: "Export audio (.wav)";
                                                clicked => { root.export-audio(r.id); }
                                            }
                                            IconBtn {
                                                size: 22px; glyph-size: 10px; glyph: "⇪"; tip: "Export package (.zip)";
                                                clicked => { root.export-package(r.id); }
                                            }
                                            IconBtn {
                                                size: 22px; glyph-size: 10px; glyph: "✧"; tip: "Apply effects";
                                                clicked => { root.fx-id = r.id; root.fx-voice = r.title; root.fx-index = 0; }
                                            }
                                            IconBtn {
                                                size: 22px; glyph-size: 10px; glyph: "#"; active: r.tags != "";
                                                tip: r.tags == "" ? "Add tags" : "Edit tags";
                                                clicked => {
                                                    lib-tag-id = r.id;
                                                    lib-tag-title = r.title;
                                                    lib-tag-value = r.tags;
                                                }
                                            }
                                            IconBtn {
                                                size: 22px; glyph-size: 10px; glyph: "✕"; tip: "Delete";
                                                clicked => { root.delete-hist(r.id); }
                                            }
                                            Rectangle { width: 6px; }
                                            Text {
                                                text: r.tags == "" ? "" : "# " + r.tags;
                                                font-size: 10px; font-family: Theme.mono; color: Theme.dim;
                                                overflow: elide; preferred-width: 0px;
                                                horizontal-stretch: 1; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                                if lib-rows.length == 0 : Text {
                                    text: "— nothing matches —"; font-size: 10.5px; font-family: Theme.mono;
                                    color: Theme.dim; horizontal-alignment: center;
                                }
                            }
                        }
                        // the same bottom player the TTS view shows
                        if player-active && player-active-visible : PlayerBar {
                            p-id: player-id; p-title: player-title; p-time: player-time;
                            p-bars: player-bars; p-playing: player-playing;
                            p-paused <=> player-paused; p-loop <=> player-loop;
                            p-volume <=> player-volume; p-pct <=> play-pct;
                            play => { root.play-hist(player-id); }
                            pause => { root.pause(); }
                            resume => { root.resume(); }
                            seek(p) => { root.seek(player-id, p); }
                            toggle-loop(on) => { root.toggle-loop(on); }
                            set-volume(v) => { root.set-volume(v); }
                            trim => { root.trim-show-hist(player-id); }
                            close => { player-active-visible = false; }
                        }
                    }

                    // ---- Settings: the last stub falls ----
                    if tab == "settings" : ScrollView {
                        VerticalLayout {
                            padding-left: 22px; padding-right: 22px; padding-bottom: 16px; spacing: 10px;

                            Text { text: "APPEARANCE"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            Rectangle {
                                height: 56px;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad; background: Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                HorizontalLayout {
                                    padding-left: 14px; padding-right: 14px; spacing: 12px;
                                    Text { text: "Theme"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; }
                                    Rectangle {}
                                    HorizontalLayout {
                                        padding: 4px; spacing: 4px;
                                        for th in [
                                            { k: "vista", l: "Aero" }, { k: "win95", l: "'95" },
                                            { k: "ps5", l: "Astro" }, { k: "rice", l: "Rice" }, { k: "tui", l: "TTY" }
                                        ] : Rectangle {
                                            border-radius: Theme.rad;
                                            background: Theme.name == th.k ? Theme.acc : transparent;
                                            TouchArea { clicked => { Theme.name = th.k; root.theme-changed(th.k); } }
                                            HorizontalLayout {
                                                padding-left: 10px; padding-right: 10px;
                                                Text { text: th.l; font-size: 11.5px; vertical-alignment: center;
                                                       color: Theme.name == th.k ? Theme.acc-fg : Theme.dim; }
                                            }
                                            height: 26px; y: parent.height / 2 - 13px;
                                        }
                                    }
                                    Text { text: "persists across restarts"; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                                }
                            }

                            Text { text: "AUDIO DEVICES"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            Rectangle {
                                height: 96px;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad; background: Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                VerticalLayout {
                                    padding: 14px; spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "Microphone"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; width: 130px; }
                                        ThemedDropdown {
                                            horizontal-stretch: 1;
                                            model: st-mic-names;
                                            current-index <=> st-mic-index;
                                            selected(i) => { root.st-pick-mic(i); }
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "System tap"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; width: 130px; }
                                        ThemedDropdown {
                                            horizontal-stretch: 1;
                                            model: st-mon-names;
                                            current-index <=> st-mon-index;
                                            selected(i) => { root.st-pick-monitor(i); }
                                        }
                                    }
                                }
                            }

                            Text { text: "DICTATION"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            Rectangle {
                                height: 92px;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad; background: Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                VerticalLayout {
                                    padding: 14px; spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "Refine transcript with LLM"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; horizontal-stretch: 1; }
                                        TBtn {
                                            label: st-refine ? "★ On" : "☆ Off"; generate: st-refine;
                                            clicked => { root.st-toggle-refine(); }
                                        }
                                    }
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: "Hyprland bind:  bind = SUPER, D, exec, syrinx-dictate toggle";
                                            font-size: 10.5px; font-family: Theme.mono; color: Theme.dim;
                                            vertical-alignment: center; overflow: elide;
                                            preferred-width: 0px; horizontal-stretch: 1;
                                        }
                                        Rectangle {
                                            width: 18px; height: 16px; border-radius: Theme.rad;
                                            background: stbc.has-hover ? Theme.acc-soft : transparent;
                                            stbi := TextInput { text: "bind = SUPER, D, exec, syrinx-dictate toggle"; read-only: true; opacity: 0; width: 1px; height: 1px; }
                                            stbc := TouchArea { clicked => { stbi.select-all(); stbi.copy(); } }
                                            Text { text: "⧉"; font-size: 10px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                    }
                                }
                            }

                            Text { text: "VOICE CONVERTER"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            Rectangle {
                                height: 96px;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad; background: Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                VerticalLayout {
                                    padding: 14px; spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "Source length cap"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; width: 160px; }
                                        ThemedDropdown {
                                            width: 140px;
                                            model: st-cap-names;
                                            current-index <=> st-cap-index;
                                            selected(i) => { root.st-pick-cap(i); }
                                        }
                                        Text { text: "longer sources need more memory"; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                                        Rectangle {}
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "Seed-VC quality steps"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; width: 160px; }
                                        ThemedDropdown {
                                            width: 140px;
                                            model: st-steps-names;
                                            current-index <=> st-steps-index;
                                            selected(i) => { root.st-pick-steps(i); }
                                        }
                                        Text { text: "more steps = better, slower (music always ≥30)"; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                                        Rectangle {}
                                    }
                                }
                            }

                            Text { text: "PATHS"; font-size: 12px; font-weight: 700; color: Theme.name == "win95" || Theme.name == "vista" ? #ffffff : Theme.dim; }
                            Rectangle {
                                height: 96px;
                                border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                border-radius: Theme.rad; background: Theme.card-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                VerticalLayout {
                                    padding: 14px; spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "Export folder"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; width: 130px; }
                                        Text {
                                            text: st-export-dir == "" ? "(ask every time)" : st-export-dir;
                                            font-size: 11px; font-family: Theme.mono; color: Theme.dim;
                                            vertical-alignment: center; overflow: elide;
                                            preferred-width: 0px; horizontal-stretch: 1;
                                        }
                                        TBtn { label: "Choose…"; clicked => { root.st-pick-export-dir(); } }
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "Data directory"; font-size: 12.5px; color: Theme.fg; vertical-alignment: center; width: 130px; }
                                        Text {
                                            text: st-data-dir; font-size: 11px; font-family: Theme.mono; color: Theme.dim;
                                            vertical-alignment: center; overflow: elide;
                                            preferred-width: 0px; horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ---- Models tab ----
                    // ============ VOICES: profile table + inspector ============
                    if tab == "voices" : HorizontalLayout {
                        padding: 16px; spacing: 14px;
                        // LEFT: searchable profile table
                        VerticalLayout {
                            horizontal-stretch: 1; spacing: 10px;
                            HorizontalLayout {
                                spacing: 10px;
                                Rectangle {
                                    width: 240px; height: 30px;
                                    background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                                    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                    if vp-search == "" : Text {
                                        x: 9px; y: 7px; text: "Search voices…";
                                        font-size: 12px; color: Theme.dim; opacity: 0.6; font-family: Theme.font;
                                    }
                                    TextInput {
                                        x: 9px; y: 7px; width: parent.width - 18px; height: parent.height - 12px;
                                        text <=> vp-search; font-size: 12.5px; color: Theme.fg; font-family: Theme.font;
                                        single-line: true; wrap: no-wrap;
                                        edited => { root.voices-search(self.text); }
                                    }
                                }
                                Rectangle {}
                                TBtn { label: "Import voice"; clicked => { root.import-voice(); } }
                                TBtn { label: "✦ Create voice"; generate: true; clicked => {
                                    // clear any stale edit-mode state before a fresh create
                                    cv-edit-id = ""; cv-model-index = 0;
                                    cv-lang-index = 0; cv-language = "en";
                                    cv-has-avatar = false;
                                    cv-error = "";
                                    cv-open = true;
                                } }
                            }
                            // column headers
                            HorizontalLayout {
                                padding-left: 60px; padding-right: 12px; spacing: 10px;
                                Text { text: "NAME"; font-size: 10.5px; font-weight: 700; color: Theme.dim; horizontal-stretch: 1; }
                                Text { text: "LANG"; font-size: 10.5px; font-weight: 700; color: Theme.dim; width: 44px; }
                                Text { text: "ENGINE"; font-size: 10.5px; font-weight: 700; color: Theme.dim; width: 96px; }
                                Text { text: "SAMPLES"; font-size: 10.5px; font-weight: 700; color: Theme.dim; width: 62px; horizontal-alignment: right; }
                                Text { text: "GENS"; font-size: 10.5px; font-weight: 700; color: Theme.dim; width: 46px; horizontal-alignment: right; }
                            }
                            ScrollView {
                                VerticalLayout {
                                    spacing: 8px;
                                    // fixed row height: ScrollView squeezes flexible children
                                    for r in vp-rows : Rectangle {
                                        height: 56px; border-radius: Theme.rad;
                                        border-width: Theme.name == "win95" ? 0px : 1px;
                                        border-color: vp-selected == r.id ? Theme.acc : Theme.brd;
                                        background: vp-selected == r.id ? Theme.acc-soft
                                            : (vrta.has-hover ? Theme.chip-bg : Theme.card-bg);
                                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: vp-selected == r.id; }
                                        vrta := TouchArea { clicked => { root.vp-select(r.id); } }
                                        HorizontalLayout {
                                            padding-left: 12px; padding-right: 12px; spacing: 10px;
                                            VerticalLayout { alignment: center; Rectangle {
                                                width: 36px; height: 36px; border-radius: 18px;
                                                border-width: 1px; border-color: Theme.brd; background: Theme.chip-bg; clip: true;
                                                if r.has-avatar : Image { width: 100%; height: 100%; source: r.avatar; image-fit: cover; }
                                                if !r.has-avatar : Text { text: "◍"; font-size: 15px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                            } }
                                            VerticalLayout {
                                                alignment: center; spacing: 1px; horizontal-stretch: 1;
                                                Text { text: r.name; font-size: 13px; font-weight: 700; color: Theme.fg; overflow: elide; preferred-width: 0px; }
                                                if r.desc != "" : Text { text: r.desc; font-size: 10.5px; color: Theme.dim; overflow: elide; preferred-width: 0px; }
                                            }
                                            VerticalLayout { alignment: center; width: 44px;
                                                Text { text: r.lang; font-size: 11.5px; font-family: Theme.mono; color: Theme.fg; } }
                                            VerticalLayout { alignment: center; width: 96px;
                                                Text { text: r.engine; font-size: 11px; font-family: Theme.mono;
                                                    color: r.engine == "follows" ? Theme.dim : Theme.acc; overflow: elide; } }
                                            VerticalLayout { alignment: center; width: 62px;
                                                Text { text: r.samples; font-size: 11.5px; font-family: Theme.mono; color: Theme.fg; horizontal-alignment: right; } }
                                            VerticalLayout { alignment: center; width: 46px;
                                                Text { text: r.gens; font-size: 11.5px; font-family: Theme.mono; color: Theme.fg; horizontal-alignment: right; } }
                                        }
                                    }
                                    if vp-rows.length == 0 : Text {
                                        text: "No voice profiles yet — ✦ Create voice to make one.";
                                        font-size: 12px; color: Theme.dim; horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                        // RIGHT: inspector
                        Rectangle {
                            width: 300px;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                            border-radius: Theme.rad; background: Theme.card-bg;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                            if vp-selected == "" : Text {
                                width: 100%; height: 100%;
                                text: "Select a voice to inspect it.";
                                font-size: 12px; color: Theme.dim;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            if vp-selected != "" : VerticalLayout {
                                padding: 14px; spacing: 8px;
                                HorizontalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 72px; height: 72px; border-radius: 36px;
                                        border-width: 1px; border-color: Theme.brd; background: Theme.chip-bg; clip: true;
                                        if vi-has-avatar : Image { width: 100%; height: 100%; source: vi-avatar; image-fit: cover; }
                                        if !vi-has-avatar : Text { text: "◍"; font-size: 26px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                                Text { text: vi-name; font-size: 15px; font-weight: 700; color: Theme.fg; horizontal-alignment: center; overflow: elide; preferred-width: 0px; }
                                if vi-desc != "" : Text { text: vi-desc; font-size: 11px; color: Theme.dim; horizontal-alignment: center; wrap: word-wrap; preferred-width: 0px; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    VerticalLayout { spacing: 1px; horizontal-stretch: 1;
                                        Text { text: "LANGUAGE"; font-size: 9.5px; font-weight: 700; color: Theme.dim; }
                                        Text { text: vi-lang; font-size: 12px; font-family: Theme.mono; color: Theme.fg; } }
                                    VerticalLayout { spacing: 1px; horizontal-stretch: 1;
                                        Text { text: "ENGINE"; font-size: 9.5px; font-weight: 700; color: Theme.dim; }
                                        Text { text: vi-engine; font-size: 12px; font-family: Theme.mono; color: Theme.fg; overflow: elide; preferred-width: 0px; } }
                                    VerticalLayout { spacing: 1px;
                                        Text { text: "GENS"; font-size: 9.5px; font-weight: 700; color: Theme.dim; }
                                        Text { text: vi-gens; font-size: 12px; font-family: Theme.mono; color: Theme.fg; } }
                                }
                                Text { text: "PERSONALITY"; font-size: 10px; font-weight: 700; color: Theme.dim; }
                                Rectangle {
                                    height: 92px;
                                    background: Theme.name == "win95" ? #ffffff : Theme.pan-bg;
                                    border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
                                    if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                    if vi-personality == "" : Text {
                                        x: 9px; y: 7px; text: "No personality set.";
                                        font-size: 11px; color: Theme.dim; opacity: 0.6; font-family: Theme.font;
                                    }
                                    visv := ScrollView {
                                        x: 9px; y: 6px; width: parent.width - 18px; height: parent.height - 12px;
                                        viewport-width: self.visible-width;
                                        viewport-height: max(self.visible-height, visti.preferred-height);
                                        visti := TextInput {
                                            page-height: visv.visible-height;
                                            text: vi-personality; read-only: true;
                                            font-size: 11.5px; color: Theme.fg; font-family: Theme.font;
                                            wrap: word-wrap; single-line: false;
                                        }
                                    }
                                }
                                Text { text: "SAMPLES"; font-size: 10px; font-weight: 700; color: Theme.dim; }
                                ScrollView {
                                    vertical-stretch: 1;
                                    VerticalLayout {
                                        spacing: 6px;
                                        for s in vi-samples : Rectangle {
                                            height: 40px; border-radius: Theme.rad;
                                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                                            background: Theme.pan-bg;
                                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                                            HorizontalLayout {
                                                padding-left: 8px; padding-right: 8px; spacing: 8px;
                                                VerticalLayout { alignment: center; Rectangle {
                                                    width: 26px; height: 26px; border-radius: Theme.rad;
                                                    background: spta.has-hover ? Theme.acc-soft : Theme.chip-bg;
                                                    border-width: 1px; border-color: Theme.brd;
                                                    spta := TouchArea { clicked => { root.vs-play(s.id); } }
                                                    Text {
                                                        text: vs-playing == s.id ? "■" : "▶";
                                                        font-size: 11px; color: Theme.acc;
                                                        horizontal-alignment: center; vertical-alignment: center;
                                                    }
                                                } }
                                                VerticalLayout { alignment: center; horizontal-stretch: 1;
                                                    Text {
                                                        text: s.text == "" ? "(no transcript)" : s.text;
                                                        font-size: 10.5px; color: s.text == "" ? Theme.dim : Theme.fg;
                                                        overflow: elide; preferred-width: 0px;
                                                    } }
                                            }
                                        }
                                        if vi-samples.length == 0 : Text {
                                            text: "No reference samples.";
                                            font-size: 11px; color: Theme.dim;
                                        }
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    TBtn { label: "✎ Edit"; clicked => { root.edit-voice(vp-selected); } }
                                    TBtn { label: "⇩ Export"; clicked => { root.export-voice(vp-selected, vi-name); } }
                                    TBtn { label: "✕"; clicked => { root.del-id = vp-selected; root.del-name = vi-name; } }
                                }
                                TBtn { label: "▷ Use in composer"; generate: true; clicked => {
                                    root.selected-voice = vp-selected;
                                    root.kokoro-active = false;
                                    root.select-voice(vp-selected);
                                    tab = "tts";
                                } }
                            }
                        }
                    }

                    if tab == "models" : ScrollView {
                        VerticalLayout {
                            padding-left: 22px; padding-right: 22px; padding-bottom: 16px; spacing: 8px;
                            for sec in [
                                { label: "VOICE & CLONING", cat: "voice" },
                                { label: "VOICE CONVERSION (⇄ CONVERTER)", cat: "vc" },
                                { label: "TRANSCRIPTION", cat: "stt" },
                                { label: "LANGUAGE (COMPOSE / REWRITE)", cat: "llm" },
                            ] : VerticalLayout {
                                spacing: 8px;
                                Text {
                                    text: sec.label; font-size: 11px; font-weight: 700;
                                    // vista/aero: the panel gradient darkens toward the
                                    // bottom and swallows the dim color
                                    color: Theme.name == "win95" || Theme.name == "vista"
                                        ? #ffffff : Theme.dim;
                                }
                                if sec.cat == "voice" : VerticalLayout {
                                    spacing: 8px;
                                    for m in voice-models : ModelRow {
                                        m: m;
                                        download => { root.download-model(m.id); }
                                        del => { root.delete-model(m.id); }
                                        activate => { root.activate-model(m.id); }
                                    }
                                }
                                if sec.cat == "vc" : VerticalLayout {
                                    spacing: 8px;
                                    for m in vc-conv-models : ModelRow {
                                        m: m; selectable: false;
                                        download => { root.download-model(m.id); }
                                        del => { root.delete-model(m.id); }
                                    }
                                }
                                if sec.cat == "stt" : VerticalLayout {
                                    spacing: 8px;
                                    for m in stt-models : ModelRow {
                                        m: m;
                                        download => { root.download-model(m.id); }
                                        del => { root.delete-model(m.id); }
                                        activate => { root.activate-model(m.id); }
                                    }
                                }
                                if sec.cat == "llm" : VerticalLayout {
                                    spacing: 8px;
                                    for m in llm-models : ModelRow {
                                        m: m;
                                        download => { root.download-model(m.id); }
                                        del => { root.delete-model(m.id); }
                                        activate => { root.activate-model(m.id); }
                                    }
                                }
                                Rectangle { height: 6px; }
                            }
                        }
                    }

                    // ---- footer ----
                    Rectangle {
                        height: 26px; border-width: 1px; border-color: Theme.brd;
                        background: Theme.name == "win95" ? #c0c0c0 : transparent;
                        HorizontalLayout {
                            padding-left: 22px; padding-right: 22px; spacing: 14px;
                            Text { text: "syrinx v0.1.0"; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                            Rectangle {}
                            Text { text: "backend: local · " + backend; font-size: 10px; font-family: Theme.mono; color: Theme.dim; vertical-alignment: center; }
                        }
                    }
                }
            }
        }
    }

    // navbar tooltip overlay — drawn here so it floats above the main panel
    navtip := Rectangle {
        x: 68px;
        y: nav-tip-y + 10px;
        height: 22px;
        width: ntl.preferred-width + 14px;
        opacity: 0;
        background: Theme.name == "win95" ? #ffffe1 : #10151be6;
        border-width: 1px; border-color: Theme.name == "win95" ? #000000 : #ffffff33;
        border-radius: Theme.name == "win95" ? 0px : 4px;
        ntl := Text {
            x: 7px; height: 100%;
            text: nav-tip; font-size: 10px; font-family: Theme.font;
            color: Theme.name == "win95" ? #000000 : #ffffff;
            vertical-alignment: center;
        }
    }
    states [
        nav-tip-shown when nav-tip != "" : {
            navtip.opacity: 1;
            in { animate navtip.opacity { duration: 100ms; delay: 1200ms; } }
            out { animate navtip.opacity { duration: 80ms; } }
        }
    ]

    // Win95 raised window frame (outermost 3D border)
    if Theme.name == "win95" : Bevel { x: 0; y: 0; width: root.width; height: root.height; }

    // --- create-voice modal ---
    if cv-open : Rectangle {
        background: #0a0f14d9;  // dimmed backdrop
        TouchArea {}            // swallow clicks to the app behind
        Rectangle {
            width: round(min(860px, root.width - 64px) / 1px) * 1px;
            height: round(min(580px, root.height - 64px) / 1px) * 1px;
            // pixel-align so text/edges render crisp (no subpixel offset)
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            // square corners: a rounded clip forces a blurry offscreen layer
            border-radius: 0px;
            clip: true;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                // header
                Rectangle {
                    height: 46px; background: Theme.tb-bg;
                    HorizontalLayout {
                        padding-left: 18px; padding-right: 12px; spacing: 10px;
                        Text { text: cv-edit-id == "" ? "Create a voice" : "Edit voice"; font-size: 15px; font-weight: 700; color: Theme.tb-fg; vertical-alignment: center; }
                        Rectangle {}
                        Rectangle {
                            width: 26px; height: 26px; y: parent.height / 2 - 13px; border-radius: Theme.rad;
                            background: xta.has-hover ? Theme.acc-soft : transparent;
                            xta := TouchArea { clicked => { root.cv-cancel(); cv-open = false; } }
                            Text { text: "✕"; font-size: 13px; color: Theme.tb-fg; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
                // body — two columns
                HorizontalLayout {
                    padding: 18px; spacing: 20px;
                    // LEFT: reference audio (in edit mode a new capture replaces
                    // the profile's current sample on save)
                    VerticalLayout {
                        horizontal-stretch: 1; spacing: 10px;
                        Text { text: "REFERENCE AUDIO"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                        HorizontalLayout {
                            spacing: 6px;
                            for t[i] in [
                                { k: "record", l: "Record" }, { k: "upload", l: "Upload" }, { k: "system", l: "System" }
                            ] : Rectangle {
                                horizontal-stretch: 1; height: 30px; border-radius: Theme.rad;
                                border-width: Theme.name == "win95" ? 0px : 1px;
                                border-color: cv-mode == t.k ? Theme.acc : Theme.btn-brd;
                                background: cv-mode == t.k ? Theme.acc-soft : Theme.btn-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: cv-mode == t.k; }
                                TouchArea { clicked => { cv-mode = t.k; } }
                                Text {
                                    text: t.l; font-size: 11.5px; font-family: Theme.font;
                                    color: cv-mode == t.k ? Theme.acc : Theme.fg;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                        // capture action area
                        Rectangle {
                            height: 92px; border-radius: Theme.rad;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
                            background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                            VerticalLayout {
                                padding: 12px; spacing: 8px; alignment: center;
                                HorizontalLayout {
                                    alignment: center;
                                    TBtn {
                                        label: cv-mode == "upload" ? "Choose file…" : (cv-recording ? "■ Stop" : "● Record");
                                        generate: cv-recording;
                                        min-width: 150px;
                                        clicked => {
                                            if (cv-mode == "upload") { root.cv-pick-file(); }
                                            else if (cv-recording) { root.cv-stop-record(); }
                                            else { root.cv-start-record(); }
                                        }
                                    }
                                }
                                Text {
                                    text: cv-sample-label != "" ? cv-sample-label
                                        : (cv-mode == "upload" ? "Pick a .wav / .mp3 / .flac clip"
                                        : cv-mode == "system" ? "System audio — use speaker/HDMI output (Bluetooth can't be tapped)"
                                        : cv-edit-id != "" ? "Optional — a new clip replaces the current sample"
                                        : "Record 5–30s of clear speech");
                                    font-size: 11px; font-family: Theme.mono; color: Theme.dim;
                                    horizontal-alignment: center; wrap: word-wrap;
                                }
                            }
                        }
                        // transcript
                        HorizontalLayout {
                            spacing: 10px;
                            Text { text: "TRANSCRIPT"; font-size: 11px; font-weight: 700; color: Theme.dim; vertical-alignment: center; }
                            Rectangle {}
                            if cv-sample-label != "" && !cv-recording : TBtn {
                                label: "✂ Trim";
                                clicked => { if (!cv-transcribing) { root.trim-show("cv"); } }
                            }
                            TBtn { label: cv-transcribing ? "Transcribing…" : "Transcribe"; clicked => { root.cv-transcribe(); } }
                        }
                        Rectangle {
                            vertical-stretch: 1;
                            background: Theme.name == "win95" ? #ffffff : Theme.card-bg;
                            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd; border-radius: Theme.rad;
                            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: true; }
                            if cv-transcript == "" : Text {
                                x: 10px; y: 8px; text: "What the reference clip says (required for cloning).";
                                font-size: 12px; color: Theme.dim; opacity: 0.6; font-family: Theme.font;
                            }
                            cvtsv := ScrollView {
                                x: 10px; y: 8px; width: parent.width - 20px; height: parent.height - 16px;
                                viewport-width: self.visible-width;
                                viewport-height: max(self.visible-height, cvtti.preferred-height);
                                cvtti := TextInput {
                                    page-height: cvtsv.visible-height;
                                    text <=> cv-transcript; font-size: 13px; color: Theme.fg; font-family: Theme.font;
                                    wrap: word-wrap; single-line: false;
                                    // keep the caret in view while typing
                                    cursor-position-changed(cpos) => {
                                        if (cpos.y + cvtsv.viewport-y < 0px) {
                                            cvtsv.viewport-y = min(0px, max(cvtsv.visible-height - self.height, -cpos.y));
                                        } else if (cpos.y + cvtsv.viewport-y > cvtsv.visible-height - 20px) {
                                            cvtsv.viewport-y = min(0px, max(cvtsv.visible-height - self.height, cvtsv.visible-height - cpos.y - 20px));
                                        }
                                    }
                                }
                            }
                        }
                    }
                    // RIGHT: voice details
                    VerticalLayout {
                        horizontal-stretch: 1; spacing: 12px;
                        Text { text: "VOICE DETAILS"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                        // avatar: shape-matched preview + picker
                        HorizontalLayout {
                            spacing: 10px;
                            Rectangle {
                                width: cv-avatar-mode == "panel" && cv-has-avatar ? 30px : 44px;
                                height: 44px;
                                border-radius: cv-avatar-mode == "panel" && cv-has-avatar ? 5px : 22px;
                                border-width: 1px; border-color: Theme.brd;
                                background: Theme.chip-bg;
                                clip: true;
                                if cv-has-avatar : Image {
                                    width: 100%; height: 100%;
                                    source: cv-avatar;
                                    image-fit: cover;
                                }
                                if !cv-has-avatar : Text {
                                    text: "◍"; font-size: 18px; color: Theme.dim;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                TBtn { label: "Choose photo…"; clicked => { root.cv-pick-avatar(); } }
                            }
                            Rectangle {}
                        }
                        LabeledInput { label: "NAME"; placeholder: "e.g. Kestrel"; value <=> cv-name; }
                        LabeledInput { label: "DESCRIPTION"; placeholder: "Short note about this voice"; value <=> cv-desc; }
                        LabeledInput { label: "PERSONALITY"; placeholder: "Optional character / style prompt"; multiline: true; value <=> cv-personality; }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "LANGUAGE"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                            ThemedDropdown {
                                model: ["English", "Japanese", "Chinese", "German", "Spanish", "French", "Italian", "Portuguese"];
                                current-index <=> cv-lang-index;
                                selected(i) => { cv-language = ["en", "ja", "zh", "de", "es", "fr", "it", "pt"][i]; }
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "DEFAULT MODEL"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                            ThemedDropdown {
                                model: cv-model-options;
                                current-index <=> cv-model-index;
                            }
                        }
                        Rectangle {}
                        Text {
                            text: "Cloned voices synthesize with the active voice engine (see Models).";
                            font-size: 10.5px; font-family: Theme.mono; color: Theme.dim; wrap: word-wrap;
                        }
                    }
                }
                // footer
                Rectangle {
                    height: 56px;
                    Rectangle { x: 0; y: 0; width: 100%; height: 1px; background: Theme.brd; }
                    HorizontalLayout {
                        padding-left: 18px; padding-right: 18px; spacing: 10px;
                        if cv-error != "" : HorizontalLayout {
                            spacing: 6px; horizontal-stretch: 1;
                            Text {
                                text: "⚠ " + cv-error;
                                font-size: 10px; font-family: Theme.mono; color: #cc3b3b;
                                vertical-alignment: center; overflow: elide;
                                horizontal-stretch: 1; preferred-width: 0px;
                            }
                            Rectangle {
                                width: 18px; height: 100%;
                                cvecti := TextInput { text: cv-error; read-only: true; opacity: 0; width: 1px; height: 1px; }
                                Rectangle {
                                    width: 18px; height: 16px; y: parent.height / 2 - 8px; border-radius: Theme.rad;
                                    background: cvecta.has-hover ? Theme.acc-soft : transparent;
                                    cvecta := TouchArea { clicked => { cvecti.select-all(); cvecti.copy(); } }
                                    Text { text: "⧉"; font-size: 10px; color: Theme.dim; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                        if cv-error == "" : Rectangle { horizontal-stretch: 1; }
                        TBtn { label: "Cancel"; clicked => { root.cv-cancel(); cv-open = false; } }
                        TBtn {
                            label: cv-edit-id != "" ? (cv-creating ? "Saving…" : "✦ Save changes")
                                 : (cv-creating ? "Creating…" : "✦ Create voice");
                            generate: true; min-width: 150px;
                            clicked => { root.cv-create(); }
                        }
                    }
                }
            }
        }
    }

    // --- apply-effects-to-history dialog ---
    if fx-id != "" : Rectangle {
        background: #0a0f14d9;
        TouchArea {}  // swallow clicks to the app behind
        Rectangle {
            width: 380px; height: 176px;
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            border-radius: 0px; clip: true;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                padding: 18px; spacing: 10px;
                Text { text: "Apply effects"; font-size: 15px; font-weight: 700; color: Theme.fg; }
                Text {
                    text: "Process \"" + fx-voice + "\" with a preset. The result is saved as a new history clip.";
                    font-size: 12px; color: Theme.dim; wrap: word-wrap;
                }
                ThemedDropdown {
                    model: composer-effects;
                    current-index <=> fx-index;
                }
                Rectangle {}
                HorizontalLayout {
                    spacing: 10px;
                    TBtn { label: "✎ Presets…"; clicked => { fx-id = ""; root.fxe-show(); } }
                    Rectangle {}
                    TBtn { label: "Cancel"; clicked => { fx-id = ""; } }
                    TBtn {
                        label: "✦ Apply"; generate: true; min-width: 110px;
                        clicked => {
                            if (fx-index > 0) {
                                root.apply-fx(fx-id, fx-index);
                                fx-id = "";
                            }
                        }
                    }
                }
            }
        }
    }

    // --- delete-voice confirm dialog ---
    if del-id != "" : Rectangle {
        background: #0a0f14d9;
        TouchArea {}  // swallow clicks to the app behind
        Rectangle {
            width: 380px; height: 158px;
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            border-radius: 0px; clip: true;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                padding: 18px; spacing: 10px;
                Text { text: "Delete voice"; font-size: 15px; font-weight: 700; color: Theme.fg; }
                Text {
                    text: "Delete \"" + del-name + "\"? Its reference samples are removed too. Generated clips stay in history.";
                    font-size: 12px; color: Theme.dim; wrap: word-wrap;
                }
                Rectangle {}
                HorizontalLayout {
                    spacing: 10px; alignment: end;
                    TBtn { label: "Cancel"; clicked => { del-id = ""; del-name = ""; } }
                    TBtn {
                        label: "Delete"; generate: true; min-width: 110px;
                        clicked => { root.delete-voice(del-id); del-id = ""; del-name = ""; }
                    }
                }
            }
        }
    }

    // --- library tag editor ---
    if lib-tag-id != "" : Rectangle {
        background: #0a0f14d9;
        TouchArea {}  // swallow clicks to the app behind
        Rectangle {
            width: 420px; height: 172px;
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            border-radius: 0px; clip: true;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                padding: 18px; spacing: 10px;
                Text { text: "Tags — " + lib-tag-title; font-size: 15px; font-weight: 700; color: Theme.fg; overflow: elide; }
                LabeledInput {
                    label: "COMMA-SEPARATED"; placeholder: "e.g. demo, piccolo, keeper";
                    value <=> lib-tag-value; vertical-stretch: 0;
                }
                Rectangle {}
                HorizontalLayout {
                    spacing: 10px; alignment: end;
                    TBtn { label: "Cancel"; clicked => { lib-tag-id = ""; } }
                    TBtn { label: "Save tags"; generate: true; min-width: 110px; clicked => { root.lib-save-tags(); } }
                }
            }
        }
    }

    // --- effects chain editor modal ---
    if fxe-open : Rectangle {
        background: #0a0f14d9;
        TouchArea {}  // swallow clicks to the app behind
        Rectangle {
            width: 680px; height: 520px;
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            border-radius: 0px; clip: true;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            HorizontalLayout {
                padding: 18px; spacing: 14px;
                // LEFT: preset list
                VerticalLayout {
                    width: 180px; spacing: 8px;
                    Text { text: "EFFECT PRESETS"; font-size: 11px; font-weight: 700; color: Theme.dim; }
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 4px;
                            for p[i] in fxe-presets : Rectangle {
                                height: 30px; border-radius: Theme.rad;
                                background: i == fxe-preset-index ? Theme.acc-soft
                                    : (pta.has-hover ? Theme.chip-bg : transparent);
                                pta := TouchArea { clicked => { root.fxe-load(i); } }
                                HorizontalLayout {
                                    padding-left: 8px; padding-right: 8px; spacing: 6px;
                                    Text {
                                        text: p.name; font-size: 12px; color: Theme.fg;
                                        overflow: elide; vertical-alignment: center; horizontal-stretch: 1;
                                    }
                                    if p.builtin : Text {
                                        text: "◇"; font-size: 10px; color: Theme.dim; vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                    TBtn { label: "＋ New preset"; clicked => { root.fxe-new(); } }
                }
                Rectangle { width: 1px; background: Theme.brd; }
                // RIGHT: chain editor
                VerticalLayout {
                    horizontal-stretch: 1; spacing: 8px;
                    HorizontalLayout {
                        spacing: 10px;
                        LabeledInput { label: "NAME"; placeholder: "e.g. Cave Troll"; value <=> fxe-name; horizontal-stretch: 1; }
                        LabeledInput { label: "DESCRIPTION"; placeholder: "optional"; value <=> fxe-desc; horizontal-stretch: 2; }
                    }
                    if fxe-builtin : Text {
                        text: "Built-in preset — saving creates your own editable copy.";
                        font-size: 10px; font-family: Theme.mono; color: Theme.dim;
                    }
                    // the chain: reorderable rows, click a row to edit its params
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 6px;
                            for r[i] in fxe-chain : Rectangle {
                                // fixed height per state so the ScrollView scrolls
                                height: 32px + (r.expanded ? fxe-params.length * 38px + 10px : 0px);
                                border-width: Theme.name == "win95" ? 0px : 1px;
                                border-color: Theme.brd; border-radius: Theme.rad;
                                background: r.enabled ? Theme.card-bg : Theme.pan-bg;
                                if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
                                rta := TouchArea { clicked => { root.fxe-expand(i); } }
                                VerticalLayout {
                                    HorizontalLayout {
                                        height: 32px; padding-left: 8px; padding-right: 4px; spacing: 2px;
                                        Text {
                                            text: r.expanded ? "▾" : "▸"; font-size: 10px; color: Theme.dim;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: " " + r.label; font-size: 12px; font-weight: 700;
                                            color: r.enabled ? Theme.fg : Theme.dim;
                                            vertical-alignment: center; overflow: elide; horizontal-stretch: 1;
                                        }
                                        IconBtn { size: 22px; glyph-size: 10px; glyph: "▲"; tip: "Move up"; clicked => { root.fxe-move(i, -1); } }
                                        IconBtn { size: 22px; glyph-size: 10px; glyph: "▼"; tip: "Move down"; clicked => { root.fxe-move(i, 1); } }
                                        IconBtn {
                                            size: 22px; glyph-size: 11px; glyph: "⏻"; active: r.enabled;
                                            tip: r.enabled ? "Bypass" : "Enable";
                                            clicked => { root.fxe-toggle(i); }
                                        }
                                        IconBtn { size: 22px; glyph-size: 10px; glyph: "✕"; tip: "Remove"; clicked => { root.fxe-remove(i); } }
                                    }
                                    if r.expanded : VerticalLayout {
                                        padding-left: 22px; padding-right: 10px; padding-bottom: 10px; spacing: 4px;
                                        for pm[j] in fxe-params : VerticalLayout {
                                            height: 38px; spacing: 3px;
                                            HorizontalLayout {
                                                Text { text: pm.label; font-size: 10.5px; color: Theme.dim; horizontal-stretch: 1; }
                                                Text { text: pm.value-text; font-size: 10.5px; font-family: Theme.mono; color: Theme.fg; }
                                            }
                                            Rectangle {
                                                height: 14px;
                                                Rectangle {
                                                    y: 4.5px; height: 5px; border-radius: 2.5px; background: Theme.chip-bg;
                                                    Rectangle {
                                                        x: 0; y: 0; height: 100%; border-radius: 2.5px;
                                                        width: parent.width * pm.norm;
                                                        background: Theme.acc;
                                                    }
                                                }
                                                psta := TouchArea {
                                                    clicked => { root.fxe-param(j, max(0.0, min(1.0, psta.mouse-x / self.width))); }
                                                    moved => {
                                                        if (self.pressed) {
                                                            root.fxe-param(j, max(0.0, min(1.0, psta.mouse-x / self.width)));
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            if fxe-chain.length == 0 : Text {
                                text: "— empty chain: add an effect below —";
                                font-size: 10.5px; font-family: Theme.mono; color: Theme.dim;
                                horizontal-alignment: center;
                            }
                        }
                    }
                    adddd := ThemedDropdown {
                        up: true;
                        model: fxe-add-model;
                        selected(i) => {
                            if (i > 0) { root.fxe-add-effect(i - 1); }
                            adddd.current-index = 0;
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: fxe-status; font-size: 10.5px; font-family: Theme.mono;
                            color: Theme.dim; vertical-alignment: center; horizontal-stretch: 1;
                            overflow: elide;
                        }
                        TBtn {
                            label: "▶ Preview";
                            clicked => { if (fxe-can-preview && fxe-chain.length > 0) { root.fxe-preview(); } }
                        }
                        if fxe-can-delete : TBtn { label: "✕ Delete"; clicked => { root.fxe-delete(); } }
                        TBtn { label: "▤ Save"; generate: true; clicked => { root.fxe-save(); } }
                        TBtn { label: "Close"; clicked => { fxe-open = false; } }
                    }
                }
            }
        }
    }

    // --- trim dialog: drag the handles, audition the selection, apply ---
    if trim-open : Rectangle {
        background: #0a0f14d9;
        TouchArea {}  // swallow clicks to the app behind
        Rectangle {
            width: 580px; height: 236px;
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            VerticalLayout {
                padding: 18px; spacing: 10px;
                Text { text: "✂ Trim — " + trim-title; font-size: 15px; font-weight: 700; color: Theme.fg; overflow: elide; }
                Text { text: "Drag on the waveform to move the nearest handle — the lit region is what's kept."; font-size: 11px; color: Theme.dim; }
                // waveform + selection handles
                Rectangle {
                    height: 72px; border-radius: Theme.rad; background: Theme.chip-bg; clip: true;
                    HorizontalLayout {
                        padding-left: 4px; padding-right: 4px; spacing: 0px;
                        for b[i] in trim-bars : Rectangle {
                            horizontal-stretch: 1;
                            Rectangle {
                                width: parent.width * 0.66;
                                height: max(2px, b * 58px);
                                y: (parent.height - self.height) / 2;
                                border-radius: self.width / 2;
                                background: i >= trim-start * trim-bars.length && i < trim-end * trim-bars.length
                                    ? Theme.wave : Theme.wave-dim;
                            }
                        }
                    }
                    Rectangle { x: trim-start * parent.width - 1px; width: 2px; height: 100%; background: Theme.acc; }
                    Rectangle { x: trim-end * parent.width - 1px; width: 2px; height: 100%; background: Theme.acc; }
                    trimta := TouchArea {
                        // whichever handle is nearer to the press follows the drag
                        property <bool> drag-end;
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down) {
                                drag-end = trimta.mouse-x / self.width > (trim-start + trim-end) / 2;
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                if (drag-end) {
                                    trim-end = max(trim-start + 0.02, min(1.0, trimta.mouse-x / self.width));
                                } else {
                                    trim-start = max(0.0, min(trim-end - 0.02, trimta.mouse-x / self.width));
                                }
                            }
                        }
                        clicked => {
                            if (drag-end) {
                                trim-end = max(trim-start + 0.02, min(1.0, trimta.mouse-x / self.width));
                            } else {
                                trim-start = max(0.0, min(trim-end - 0.02, trimta.mouse-x / self.width));
                            }
                        }
                    }
                }
                HorizontalLayout {
                    Text {
                        text: "in " + round(trim-start * trim-duration * 10) / 10 + "s";
                        font-size: 10.5px; font-family: Theme.mono; color: Theme.dim;
                    }
                    Rectangle {}
                    Text {
                        text: "keeps " + round((trim-end - trim-start) * trim-duration * 10) / 10 + "s of " + round(trim-duration * 10) / 10 + "s";
                        font-size: 10.5px; font-family: Theme.mono; color: Theme.fg;
                    }
                    Rectangle {}
                    Text {
                        text: "out " + round(trim-end * trim-duration * 10) / 10 + "s";
                        font-size: 10.5px; font-family: Theme.mono; color: Theme.dim;
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    TBtn {
                        label: trim-playing ? "■ Stop" : "▶ Selection";
                        clicked => {
                            if (trim-playing) { root.trim-preview-stop(); }
                            else { root.trim-preview(trim-start, trim-end); }
                        }
                    }
                    Rectangle {}
                    TBtn { label: "Cancel"; clicked => { root.trim-preview-stop(); trim-open = false; } }
                    TBtn {
                        label: "✂ Apply"; generate: true;
                        clicked => { root.trim-apply(trim-start, trim-end); }
                    }
                }
            }
        }
    }

    // --- avatar dialog: pick the shape, then drag to pan / slider to zoom ---
    if crop-open : Rectangle {
        background: #0a0f14d9;
        TouchArea {}  // swallow clicks to the app behind
        Rectangle {
            width: 340px; height: crop-stage == "mode" ? 300px : 404px;
            x: round((parent.width - self.width) / 2 / 1px) * 1px;
            y: round((parent.height - self.height) / 2 / 1px) * 1px;
            background: Theme.modal-bg;
            border-width: Theme.name == "win95" ? 0px : 1px; border-color: Theme.brd;
            border-radius: 0px;
            if Theme.name == "win95" : Bevel { width: 100%; height: 100%; }
            // STAGE 1: how should the photo appear on the card?
            if crop-stage == "mode" : VerticalLayout {
                padding: 18px; spacing: 12px;
                Text { text: "Avatar style"; font-size: 15px; font-weight: 700; color: Theme.fg; }
                Text { text: "How should the photo appear on the card?"; font-size: 11px; color: Theme.dim; }
                HorizontalLayout {
                    spacing: 12px;
                    for opt in [
                        { k: "circle", glyph: "●", label: "Big circle", hint: "Round portrait, top-right" },
                        { k: "panel", glyph: "▮", label: "Side panel", hint: "Fills the card's right third" },
                    ] : Rectangle {
                        horizontal-stretch: 1; height: 130px;
                        border-radius: Theme.rad;
                        border-width: Theme.name == "win95" ? 0px : 1px;
                        border-color: mta.has-hover ? Theme.acc : Theme.btn-brd;
                        background: mta.has-hover ? Theme.acc-soft : Theme.btn-bg;
                        if Theme.name == "win95" : Bevel { width: 100%; height: 100%; sunken: mta.pressed; }
                        mta := TouchArea {
                            clicked => { crop-mode = opt.k; crop-stage = "crop"; }
                        }
                        VerticalLayout {
                            alignment: center; spacing: 8px;
                            Text { text: opt.glyph; font-size: 30px; color: Theme.acc; horizontal-alignment: center; }
                            Text { text: opt.label; font-size: 12.5px; font-weight: 700; color: Theme.fg; horizontal-alignment: center; }
                            Text { text: opt.hint; font-size: 10px; color: Theme.dim; horizontal-alignment: center; wrap: word-wrap; }
                        }
                    }
                }
                Rectangle {}
                HorizontalLayout {
                    alignment: end;
                    TBtn { label: "Cancel"; clicked => { crop-open = false; root.crop-done(false); } }
                }
            }
            // STAGE 2: shape-matched crop viewport
            if crop-stage == "crop" : VerticalLayout {
                padding: 18px; spacing: 12px;
                Text { text: "Crop photo"; font-size: 15px; font-weight: 700; color: Theme.fg; }
                Text { text: "Drag to position · slider to zoom"; font-size: 11px; color: Theme.dim; }
                // viewport previews exactly what the card will show
                HorizontalLayout {
                    alignment: center;
                    vp := Rectangle {
                        property <float> vw: crop-mode == "panel" ? 132 : 220;
                        property <float> vh: 220;
                        width: self.vw * 1px; height: 220px;
                        border-radius: crop-mode == "panel" ? 8px : 110px;
                        border-width: 2px; border-color: Theme.acc;
                        background: #000000;
                        clip: true;
                        property <float> srcw: crop-src.width;
                        property <float> srch: crop-src.height;
                        // crop rect (source px) with the viewport's aspect
                        property <float> cw: min(self.srcw, self.srch * self.vw / self.vh) / crop-zoom;
                        property <float> ch: self.cw * self.vh / self.vw;
                        property <float> px-per-src: self.vw / self.cw;
                        property <float> sx: clamp(crop-cx * self.srcw - self.cw / 2, 0, max(0, self.srcw - self.cw));
                        property <float> sy: clamp(crop-cy * self.srch - self.ch / 2, 0, max(0, self.srch - self.ch));
                        Image {
                            source: crop-src;
                            x: -vp.sx * vp.px-per-src * 1px;
                            y: -vp.sy * vp.px-per-src * 1px;
                            width: vp.srcw * vp.px-per-src * 1px;
                            height: vp.srch * vp.px-per-src * 1px;
                        }
                        dragta := TouchArea {
                            property <float> start-cx;
                            property <float> start-cy;
                            property <length> start-mx;
                            property <length> start-my;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down) {
                                    self.start-cx = crop-cx;
                                    self.start-cy = crop-cy;
                                    self.start-mx = self.mouse-x;
                                    self.start-my = self.mouse-y;
                                }
                            }
                            moved => {
                                crop-cx = clamp(
                                    self.start-cx - (self.mouse-x - self.start-mx) / (vp.vw * 1px) * vp.cw / vp.srcw,
                                    vp.cw / (2 * vp.srcw), 1 - vp.cw / (2 * vp.srcw));
                                crop-cy = clamp(
                                    self.start-cy - (self.mouse-y - self.start-my) / 220px * vp.ch / vp.srch,
                                    vp.ch / (2 * vp.srch), 1 - vp.ch / (2 * vp.srch));
                            }
                        }
                    }
                }
                // zoom slider (1x .. 4x)
                HorizontalLayout {
                    spacing: 10px;
                    Text { text: "−"; font-size: 14px; color: Theme.dim; vertical-alignment: center; }
                    Rectangle {
                        horizontal-stretch: 1;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                height: 5px; border-radius: 2.5px; background: Theme.chip-bg;
                                Rectangle {
                                    x: 0; y: 0; height: 100%; border-radius: 2.5px;
                                    width: parent.width * (crop-zoom - 1.0) / 3.0;
                                    background: Theme.acc;
                                }
                            }
                        }
                        zta := TouchArea {
                            clicked => { crop-zoom = 1.0 + max(0.0, min(1.0, zta.mouse-x / self.width)) * 3.0; }
                            moved => {
                                if (zta.pressed) {
                                    crop-zoom = 1.0 + max(0.0, min(1.0, zta.mouse-x / self.width)) * 3.0;
                                }
                            }
                        }
                    }
                    Text { text: "+"; font-size: 14px; color: Theme.dim; vertical-alignment: center; }
                }
                Rectangle {}
                HorizontalLayout {
                    spacing: 10px; alignment: end;
                    TBtn { label: "Cancel"; clicked => { crop-open = false; root.crop-done(false); } }
                    TBtn {
                        label: "✦ Use photo"; generate: true; min-width: 120px;
                        clicked => { crop-open = false; root.crop-done(true); }
                    }
                }
            }
        }
    }
}

# Rust
/target
**/*.rs.bk
# NOTE: Cargo.lock IS committed — this is a binary/application workspace.

# Python engine
.venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Model weights / caches (never commit these)
*.safetensors
*.gguf
*.pt
*.pth
*.onnx
*.ckpt
models/

# Secrets / local config
.env
*.local

# Local dev notes (kept out of the public repo)
HANDOFF.md
HANDOFF-4090*

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# isolated engine venvs (luxtts, seedvc, …)
engine/.venv-*/

# seed-vc downloads to ./checkpoints relative to its cwd — the worker runs
# with cwd pinned OUTSIDE the repo, but never let a stray run commit weights
/checkpoints/
.coverage
htmlcov/
.pytest_cache/
